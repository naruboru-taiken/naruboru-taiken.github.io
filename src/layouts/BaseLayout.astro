---
import { useTranslations, SUPPORTED_LANGS } from '../i18n/ui';
import type { Lang } from '../i18n/ui';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  lang?: Lang;
  pagePath?: string; // e.g. '/' or '/stories' — used to build language-switch URLs
}
const {
  title,
  description,
  ogImage,
  lang = 'ja',
  pagePath = '/',
} = Astro.props;

const t = useTranslations(lang);
const defaultDesc = t('site.description');
const resolvedDescription = description ?? defaultDesc;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteUrl = 'https://naruboru-taiken.github.io';
const pageUrl = `${siteUrl}${Astro.url.pathname}`;
const ogImageUrl = ogImage ?? `${siteUrl}/ogp.png`;
const siteName = t('site.name');
const fullTitle = `${title} | ${siteName}`;

const isRTL = lang === 'ar';

// Build language switch URLs
function langUrl(targetLang: Lang): string {
  if (targetLang === 'ja') return `${base}${pagePath}`;
  return `${base}/${targetLang}${pagePath}`;
}

const allLangs: Lang[] = ['ja', ...SUPPORTED_LANGS];
---
<!doctype html>
<html lang={lang} dir={isRTL ? 'rtl' : 'ltr'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={resolvedDescription} />
    <title>{fullTitle}</title>

    <!-- OGP（SNSシェア用） -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={lang === 'ja' ? 'ja_JP' : lang} />

    <!-- Twitter / X カード -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href={`${base}/styles/global.css`} />
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href={`${base}${lang === 'ja' ? '/' : '/' + lang + '/'}`} class="site-logo">
          <span class="logo-mark">忍</span>
          <span class="logo-text">{siteName}</span>
        </a>
        <nav class="site-nav" id="site-nav">
          <a href={lang === 'ja' ? `${base}/stories` : `${base}/${lang}/stories`}>{t('nav.read')}</a>
          <a href={lang === 'ja' ? `${base}/characters` : `${base}/${lang}/characters`}>{t('nav.characters')}</a>
          <a href={lang === 'ja' ? `${base}/submit` : `${base}/${lang}/submit`} class="nav-cta">{t('nav.submit')}</a>

          <!-- 言語切り替え -->
          <div class="lang-switcher">
            <button class="lang-switcher-btn" aria-label={t('lang.label')} aria-haspopup="listbox" aria-expanded="false" id="lang-btn">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/>
                <line x1="2" y1="12" x2="22" y2="12"/>
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
              </svg>
              <span>{t(`lang.${lang}`)}</span>
            </button>
            <ul class="lang-menu" role="listbox" id="lang-menu" hidden>
              {allLangs.map(l => (
                <li role="option" aria-selected={l === lang}>
                  <a href={langUrl(l)} hreflang={l}>{t(`lang.${l}`)}</a>
                </li>
              ))}
            </ul>
          </div>
        </nav>
        <button class="nav-toggle" id="nav-toggle" aria-label={t('nav.open')} aria-expanded="false">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <p class="footer-logo">
          <span class="logo-mark-small">忍</span> {siteName}
        </p>
        <nav class="footer-nav">
          <a href={lang === 'ja' ? `${base}/` : `${base}/${lang}/`}>{t('footer.home')}</a>
          <a href={lang === 'ja' ? `${base}/stories` : `${base}/${lang}/stories`}>{t('footer.stories')}</a>
          <a href={lang === 'ja' ? `${base}/characters` : `${base}/${lang}/characters`}>{t('footer.characters')}</a>
          <a href={lang === 'ja' ? `${base}/guidelines` : `${base}/${lang}/guidelines`}>{t('footer.guidelines')}</a>
          <a href={lang === 'ja' ? `${base}/privacy` : `${base}/${lang}/privacy`}>{t('footer.privacy')}</a>
          <a href={lang === 'ja' ? `${base}/submit` : `${base}/${lang}/submit`}>{t('footer.submit')}</a>
        </nav>
        <p class="footer-note">
          {t('footer.unofficial')}
        </p>
      </div>
    </footer>
  </body>
  <script>
    // ハンバーガーメニュー
    const toggle = document.getElementById('nav-toggle');
    const nav = document.getElementById('site-nav');
    const openLabel = toggle?.getAttribute('aria-label') ?? 'Open menu';
    toggle?.addEventListener('click', () => {
      const isOpen = nav?.classList.toggle('nav-open');
      toggle.setAttribute('aria-expanded', String(isOpen));
      toggle.setAttribute('aria-label', isOpen ? openLabel.replace('Open', 'Close').replace('開く', '閉じる').replace('فتح', 'إغلاق').replace('Abrir', 'Cerrar').replace('Ouvrir', 'Fermer') : openLabel);
    });
    nav?.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        nav.classList.remove('nav-open');
        toggle?.setAttribute('aria-expanded', 'false');
        toggle?.setAttribute('aria-label', openLabel);
      });
    });

    // 言語切り替えドロップダウン
    const langBtn = document.getElementById('lang-btn');
    const langMenu = document.getElementById('lang-menu');
    langBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = langMenu?.hasAttribute('hidden') === false;
      if (isOpen) {
        langMenu?.setAttribute('hidden', '');
        langBtn.setAttribute('aria-expanded', 'false');
      } else {
        langMenu?.removeAttribute('hidden');
        langBtn.setAttribute('aria-expanded', 'true');
      }
    });
    document.addEventListener('click', () => {
      langMenu?.setAttribute('hidden', '');
      langBtn?.setAttribute('aria-expanded', 'false');
    });
  </script>
</html>

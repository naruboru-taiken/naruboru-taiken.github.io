---
export interface Props {
  title: string;
  description?: string;
  ogImage?: string; // ページ固有のOGP画像URLを渡せる（省略時はデフォルト画像を使用）
}
const {
  title,
  description = 'ナルボルファンの「作品との出会いからオタクになるまで」のリアルな体験談を集めたサイトです。',
  ogImage,
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteUrl = 'https://chachaTSUBAKI.github.io/naruboru-fan-site';
const pageUrl = `${siteUrl}${Astro.url.pathname}`;
const ogImageUrl = ogImage ?? `${siteUrl}/ogp.png`;
const fullTitle = `${title} | ナルボル体験談`;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>

    <!-- OGP（SNSシェア用） -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ナルボル体験談" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="ja_JP" />

    <!-- Twitter / X カード -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href={`${base}/styles/global.css`} />
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href={`${base}/`} class="site-logo">
          <span class="logo-mark">忍</span>
          <span class="logo-text">ナルボル体験談</span>
        </a>
        <nav class="site-nav">
          <a href={`${base}/stories`}>体験談を読む</a>
          <a href={`${base}/submit`} class="nav-cta">体験談を投稿する</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <p class="footer-logo">
          <span class="logo-mark-small">忍</span> ナルボル体験談
        </p>
        <nav class="footer-nav">
          <a href={`${base}/`}>ホーム</a>
          <a href={`${base}/stories`}>体験談一覧</a>
          <a href={`${base}/guidelines`}>投稿ガイドライン</a>
          <a href={`${base}/privacy`}>プライバシーポリシー</a>
          <a href={`${base}/submit`}>投稿する</a>
        </nav>
        <p class="footer-note">
          ※ 本サイトはファンによる非公式サイトです。NARUTO・BORUTOの著作権は岸本斉史先生・集英社および池本幹雄先生・小太刀右京先生に帰属します。本サイトは権利者とは一切関係ありません。
        </p>
      </div>
    </footer>
  </body>
</html>

---
import { getStoryText, getAgeGroupLabel, getCharaName } from '../i18n/ui';
import type { Lang } from '../i18n/ui';
import FlagIcon from './FlagIcon.astro';

export interface Props {
  story: {
    id: string;
    displayName: string;
    ageGroup?: string;
    favoriteCharacter?: string;
    firstSeries: string;
    firstMedia: string;
    catchphrase?: string | null;
    mainStory?: string | null;
    triggerScene?: string | null;
    imageUrl?: string | null;
    publishedAt: string;
    isSeedContent?: boolean;
    translations?: Record<string, any>;
  };
  lang?: Lang;
}
const { story, lang = 'ja' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function truncate(text: string, max = 60) {
  return text.length > max ? text.slice(0, max) + '…' : text;
}

const catchphrase = getStoryText(story, lang, 'catchphrase');
const mainStory = getStoryText(story, lang, 'mainStory');
const triggerScene = getStoryText(story, lang, 'triggerScene');

const displayCatchphrase =
  catchphrase ||
  (mainStory ? truncate(mainStory) : null) ||
  (triggerScene ? truncate(triggerScene) : null) ||
  '';

const ageLabel = getAgeGroupLabel(story.ageGroup, lang);
const charaName = getCharaName(story.favoriteCharacter, lang);

// 国旗は絵文字ではなくSVG（対応国のみ）
const countryToCode: Record<string, string> = {
  '日本': 'JP',
  'ブラジル': 'BR', 'Brasil': 'BR',
  '韓国': 'KR',
  'タイ': 'TH',
  'イギリス': 'GB', 'UK': 'GB',
  'アメリカ': 'US', 'United States': 'US', 'USA': 'US',
  '中国': 'CN',
  'フランス': 'FR', 'France': 'FR',
  'ドイツ': 'DE',
  'イタリア': 'IT',
};
const countryName = (story as any).country as string | undefined;
const countryCode = countryName ? (countryToCode[countryName] ?? null) : null;

// Labels
const agePrefix = lang === 'ja' ? '出会いは' : (lang === 'ar' ? 'عمر الاكتشاف: ' : '');
const favPrefix = lang === 'ja' ? '推し：' : (lang === 'ar' ? 'المفضل: ' : '');
const readMore = lang === 'ja' ? '続きを読む →' : (lang === 'ar' ? 'اقرأ المزيد ←' : 'Read more →');

// Story URL: for [lang] pages, link to /[lang]/stories/[id]
const storyPath = lang === 'ja'
  ? `${base}/stories/${story.id}`
  : `${base}/${lang}/stories/${story.id}`;
---

<article class="story-card"
  data-series={story.firstSeries}
  data-age-group={story.ageGroup ?? ''}
  data-chara={story.favoriteCharacter ?? ''}
  data-published-at={story.publishedAt}
  data-story-id={story.id}
  data-seed={story.isSeedContent ? 'true' : undefined}
>
  {story.imageUrl && (
    <div class="card-image">
      <img src={story.imageUrl} alt={story.displayName} loading="lazy" />
    </div>
  )}
  <div class="card-body">
    <div class="card-tags">
      <span class="badge-read" hidden>既読</span>
      <span class="badge-new" hidden>NEW</span>
      {story.firstSeries && <span class="tag">{story.firstSeries}</span>}
      {story.firstMedia && <span class="tag tag-media">{story.firstMedia}</span>}
    </div>
    <blockquote class="card-catchphrase">
      {displayCatchphrase}
    </blockquote>
    <div class="card-meta">
      <span class="card-avatar" aria-hidden="true">{story.displayName.charAt(0)}</span>
      <div>
        <span class="card-name">{story.displayName}</span>
        {ageLabel && <span class="card-age">・{agePrefix}{ageLabel}</span>}
        {charaName && (
          <span class="card-chara">・{favPrefix}{charaName}</span>
        )}
        {countryName && (
          <span class="card-country">
            ・{countryName}
            {countryCode && <span class="card-country-flag" aria-hidden="true"><FlagIcon code={countryCode} /></span>}
          </span>
        )}
      </div>
    </div>
  </div>
  <button type="button" class="card-fav-btn" aria-label="お気に入りに保存" aria-pressed="false">
    <svg class="card-fav-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path
        d="M12.1 20.3s-7.1-4.4-9.3-8.1C.6 8.4 2.1 5.4 5.1 4.6c1.7-.5 3.6.1 4.8 1.5 1.2-1.4 3.1-2 4.8-1.5 3 .8 4.5 3.8 2.3 7.6-2.2 3.7-9.3 8.1-9.3 8.1z"
        stroke="currentColor"
        stroke-width="2"
        stroke-linejoin="round"
      />
    </svg>
  </button>
  <a href={storyPath} class="card-link" aria-label={story.displayName}>
    <span class="card-link-text">{readMore}</span>
  </a>
</article>

<script>
document.querySelectorAll<HTMLElement>('.story-card[data-story-id]').forEach(card => {
  const id = card.dataset.storyId!;
  const publishedAt = new Date(card.dataset.publishedAt!);

  // NEWバッジ
  if ((Date.now() - publishedAt.getTime()) / 86400000 <= 7) {
    card.querySelector('.badge-new')?.removeAttribute('hidden');
  }

  // 既読バッジ
  const readList = JSON.parse(localStorage.getItem('naruboru-read') || '[]');
  if (readList.includes(id)) {
    card.querySelector('.badge-read')?.removeAttribute('hidden');
  }

  // お気に入りアイコン
  const favList = JSON.parse(localStorage.getItem('naruboru-favorites') || '[]');
  const favBtn = card.querySelector<HTMLButtonElement>('.card-fav-btn');
  if (favBtn) {
    const setFavState = (isFav: boolean) => {
      favBtn.classList.toggle('is-fav', isFav);
      favBtn.setAttribute('aria-pressed', String(isFav));
      favBtn.setAttribute('aria-label', isFav ? 'お気に入りから外す' : 'お気に入りに保存');
    };
    setFavState(favList.includes(id));
    favBtn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const list = JSON.parse(localStorage.getItem('naruboru-favorites') || '[]');
      const idx = list.indexOf(id);
      const willFav = idx === -1;
      if (willFav) list.push(id);
      else list.splice(idx, 1);
      localStorage.setItem('naruboru-favorites', JSON.stringify(list));
      setFavState(willFav);
    });
  }
});
</script>

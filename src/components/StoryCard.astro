---
export interface Props {
  story: {
    id: string;
    displayName: string;
    ageGroup?: string;
    favoriteCharacter?: string;
    firstSeries: string;
    firstMedia: string;
    catchphrase?: string | null;
    mainStory?: string | null;
    triggerScene?: string | null;
    imageUrl?: string | null;
    publishedAt: string;
    isSeedContent?: boolean;
  };
}
const { story } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function truncate(text: string, max = 60) {
  return text.length > max ? text.slice(0, max) + '…' : text;
}
const displayCatchphrase =
  story.catchphrase ||
  (story.mainStory ? truncate(story.mainStory) : null) ||
  (story.triggerScene ? truncate(story.triggerScene) : null) ||
  '';
---

<article class="story-card" data-series={story.firstSeries}>
  {story.imageUrl && (
    <div class="card-image">
      <img src={story.imageUrl} alt={story.displayName + 'の投稿画像'} loading="lazy" />
    </div>
  )}
  <div class="card-body">
    <div class="card-tags">
      <span class="tag">{story.firstSeries}</span>
      <span class="tag tag-media">{story.firstMedia}</span>
    </div>
    <blockquote class="card-catchphrase">
      &ldquo;{displayCatchphrase}&rdquo;
    </blockquote>
    <div class="card-meta">
      <span class="card-name">{story.displayName}</span>
      {story.ageGroup && <span class="card-age">・出会いは{story.ageGroup}</span>}
      {story.favoriteCharacter && (
        <span class="card-chara">・推し：{story.favoriteCharacter}</span>
      )}
    </div>
  </div>
  <a href={`${base}/stories/${story.id}`} class="card-link" aria-label={`${story.displayName}の体験談を読む`}>
    <span class="card-link-text">続きを読む →</span>
  </a>
</article>

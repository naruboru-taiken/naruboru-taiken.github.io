---
import BaseLayout from '../layouts/BaseLayout.astro';
import stories from '../data/stories.json';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="お気に入り" description="保存した体験談" lang="ja" pagePath="/favorites">
  <section class="page-header">
    <div class="page-header-inner">
      <h1 class="page-title">♥ お気に入り</h1>
      <p class="page-desc">保存した体験談の一覧です。</p>
    </div>
  </section>

  <section class="favorites-section">
    <div class="favorites-inner">
      <div id="favorites-list">
        <p class="favorites-empty">読み込み中...</p>
      </div>
      <div style="text-align:center; margin-top: 2rem;">
        <a href={`${base}/stories`} class="btn btn-outline">← 体験談一覧へ</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script define:vars={{ storiesData: stories, base }}>
const favIds = JSON.parse(localStorage.getItem('naruboru-favorites') || '[]');
const favStories = storiesData.filter(s => favIds.includes(s.id));
const container = document.getElementById('favorites-list');

if (favStories.length === 0) {
  container.innerHTML = '<p class="favorites-empty">まだお気に入りがありません。体験談の♡ボタンで保存できます。</p>';
} else {
  container.innerHTML = favStories.map(s => {
    const catchphrase = s.catchphrase || (s.mainStory ? s.mainStory.slice(0, 60) + '…' : '');
    return `
      <a href="${base}/stories/${s.id}" class="fav-item">
        <div class="fav-item-meta">
          ${s.firstSeries ? `<span class="tag">${s.firstSeries}</span>` : ''}
        </div>
        <blockquote class="fav-item-catchphrase">&#x201C;${catchphrase}&#x201D;</blockquote>
        <p class="fav-item-name">${s.displayName}</p>
      </a>
    `;
  }).join('');
}
</script>

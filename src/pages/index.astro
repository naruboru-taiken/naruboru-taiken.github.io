---
import BaseLayout from '../layouts/BaseLayout.astro';
import StoryCard from '../components/StoryCard.astro';
import stories from '../data/stories.json';

const latestStories = [...stories]
  .sort((a, b) => {
    const d = new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime();
    return d !== 0 ? d : b.id.localeCompare(a.id);
  })
  .slice(0, 9);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="ホーム" description="NARUTO・BORUTOファンの「作品に引き込まれた瞬間」のリアルな体験談を集めたサイトです。" lang="ja" pagePath="/">

  <!-- ヒーローセクション -->
  <section class="hero">
    <div class="hero-bg">
      <div class="hero-pattern"></div>
    </div>
    <div class="hero-inner">
      <p class="hero-eyebrow">NARUTO・BORUTO ファン体験談</p>
      <h1 class="hero-title">
        引き込まれたのは、<br />どんな瞬間でしたか。
      </h1>
      <p class="hero-desc">
        「友達のジャンプが目に入った」「たまたまつけたテレビで流れていた」——<br />
        きっかけは小さくても、あの瞬間がすべてを変えた。<br />
        ナルボルファンの、リアルな体験談を集めています。
      </p>
      <div class="hero-actions">
        <a href={`${base}/stories`} class="btn btn-primary">体験談をすべて読む</a>
        <a href={`${base}/submit`} class="btn btn-outline">自分の体験談を投稿する</a>
      </div>
      <p class="hero-count">
        現在 <strong>{stories.length}</strong> 件の体験談が集まっています
      </p>
    </div>
  </section>

  <!-- 最新投稿 -->
  <section class="section">
    <div class="section-inner">
      <div class="section-header">
        <h2 class="section-title">最新の体験談</h2>
        <a href={`${base}/stories`} class="section-link">すべて見る →</a>
      </div>
      <div class="card-grid">
        {latestStories.map((story) => (
          <StoryCard story={story} />
        ))}
      </div>
    </div>
  </section>

  <!-- 投稿CTA -->
  <section class="cta-section">
    <div class="cta-inner">
      <h2 class="cta-title">あなたの体験談も聞かせてください</h2>
      <p class="cta-desc">
        長文でなくていい。うまく書けなくてもいい。<br />
        あの日の記憶を、このサイトに残しませんか。
      </p>
      <a href={`${base}/submit`} class="btn btn-primary btn-large">体験談を投稿する（無料）</a>
      <p class="cta-note">
        <a href={`${base}/guidelines`}>投稿ガイドライン</a>を必ずご確認ください。
      </p>
    </div>
  </section>

</BaseLayout>

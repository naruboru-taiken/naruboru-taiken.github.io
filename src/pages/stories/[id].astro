---
import BaseLayout from '../../layouts/BaseLayout.astro';
import stories from '../../data/stories.json';

export function getStaticPaths() {
  return (stories as any[]).map((story) => ({
    params: { id: story.id },
    props: { story },
  }));
}

const { story } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function truncate(text: string, max = 60) {
  return text.length > max ? text.slice(0, max) + '…' : text;
}
const displayCatchphrase =
  story.catchphrase ||
  (story.mainStory ? truncate(story.mainStory) : null) ||
  (story.triggerScene ? truncate(story.triggerScene) : null) ||
  '';

const siteUrl = 'https://chachaTSUBAKI.github.io/naruboru-fan-site';
const storyUrl = `${siteUrl}/stories/${story.id}`;
const ogpImageUrl = `${siteUrl}/ogp/${story.id}.png`;
const shareText = `「${displayCatchphrase}」\n${story.displayName}さんのナルボル体験談 #ナルボル体験談`;
const xShareUrl = `https://x.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(storyUrl)}`;
---

<BaseLayout
  title={story.displayName + 'の体験談'}
  description={`「${story.catchphrase}」— ${story.displayName}さんのナルボル体験談`}
  ogImage={ogpImageUrl}
>
  <article class="story-detail">
    <div class="story-detail-inner">

      <!-- パンくず -->
      <nav class="breadcrumb">
        <a href={`${base}/`}>ホーム</a> &rsaquo;
        <a href={`${base}/stories`}>体験談一覧</a> &rsaquo;
        <span>{story.displayName}</span>
      </nav>

      <!-- ヘッダー -->
      <header class="story-header">
        <div class="story-tags">
          {story.firstSeries && <span class="tag tag-large">{story.firstSeries}</span>}
          {story.firstMedia && <span class="tag tag-large tag-media">{story.firstMedia}</span>}
        </div>
        <blockquote class="story-catchphrase">
          &ldquo;{displayCatchphrase}&rdquo;
        </blockquote>
        <div class="story-meta">
          <span class="story-name">{story.displayName}</span>
          {story.ageGroup && (
            <span class="story-meta-item">出会いは{story.ageGroup}</span>
          )}
          {story.favoriteCharacter && (
            <span class="story-meta-item">推し：{story.favoriteCharacter}</span>
          )}
          <span class="story-meta-item story-date">
            {new Date(story.publishedAt).toLocaleDateString('ja-JP', {
              year: 'numeric', month: 'long', day: 'numeric'
            })}
          </span>
        </div>
      </header>

      <!-- 画像（あれば） -->
      {story.imageUrl && (
        <div class="story-image">
          <img src={story.imageUrl} alt={story.imageCaption ?? story.displayName + 'の投稿画像'} />
          {story.imageCaption && <p class="story-image-caption">{story.imageCaption}</p>}
        </div>
      )}

      <!-- 本文 -->
      <div class="story-body">
        {story.mainStory ? (
          <section class="story-section">
            <h2>体験談</h2>
            <p>{story.mainStory}</p>
          </section>
        ) : (
          <>
            {story.triggerScene && (
              <section class="story-section">
                <h2>ハマるきっかけになったシーン</h2>
                <p>{story.triggerScene}</p>
              </section>
            )}

            {story.realization && (
              <section class="story-section">
                <h2>「あ、自分これ好きだ」と気づいた瞬間</h2>
                <p>{story.realization}</p>
              </section>
            )}

            {story.currentRelationship && (
              <section class="story-section">
                <h2>今のあなたとナルボルの関係</h2>
                <p>{story.currentRelationship}</p>
              </section>
            )}
          </>
        )}

        {story.favoriteScene && (
          <section class="story-section">
            <h2>特に好きなシーン・セリフ</h2>
            <p>{story.favoriteScene}</p>
          </section>
        )}

        {story.futureWish && (
          <section class="story-section story-section--wish">
            <h2>こんな作品が観てみたい</h2>
            <p>{story.futureWish}</p>
          </section>
        )}

        {story.message && (
          <section class="story-message">
            <p class="message-label">同じ作品を好きな人へ</p>
            <blockquote class="message-quote">&ldquo;{story.message}&rdquo;</blockquote>
          </section>
        )}
      </div>

      <!-- シェアボタン -->
      <div class="story-share">
        <p class="story-share-label">この体験談をシェアする</p>
        <a href={xShareUrl} target="_blank" rel="noopener noreferrer" class="btn btn-x-share">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.742l7.732-8.857L1.555 2.25H8.08l4.27 5.646L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
          </svg>
          Xでシェア
        </a>
        <button type="button" id="ig-share-btn" class="btn btn-ig-share">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <circle cx="12" cy="12" r="5"/>
            <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" stroke="none"/>
          </svg>
          Instagramストーリーズ
        </button>
      </div>

      <!-- ナビゲーション -->
      <nav class="story-nav">
        <a href={`${base}/stories`} class="btn btn-outline">&larr; 一覧に戻る</a>
        <a href={`${base}/submit`} class="btn btn-primary">あなたの体験談を投稿する</a>
      </nav>

    </div>
  </article>
</BaseLayout>

<script define:vars={{
  catchphrase: displayCatchphrase,
  displayName: story.displayName,
  storyUrl,
  firstSeries: story.firstSeries,
  firstMedia: story.firstMedia,
  mainStory: story.mainStory ?? null,
  triggerScene: story.triggerScene ?? null,
  realization: story.realization ?? null,
  currentRelationship: story.currentRelationship ?? null,
  favoriteScene: story.favoriteScene ?? null,
  futureWish: story.futureWish ?? null,
  message: story.message ?? null,
}}>
const btn = document.getElementById('ig-share-btn');
const originalHTML = btn.innerHTML;

btn.addEventListener('click', async () => {
  btn.disabled = true;
  btn.textContent = '画像を生成中…';

  try {
    // CSSで宣言されたフォント（Noto Sans JP）がcanvasで使えるまで待機
    await document.fonts.ready;

    const canvas = document.createElement('canvas');
    canvas.width = 1080;
    canvas.height = 1920;
    const ctx = canvas.getContext('2d');

    // ── 背景 ──
    ctx.fillStyle = '#1a1a2e';
    ctx.fillRect(0, 0, 1080, 1920);

    const g1 = ctx.createRadialGradient(160, 360, 0, 160, 360, 560);
    g1.addColorStop(0, 'rgba(232,98,26,0.22)');
    g1.addColorStop(1, 'rgba(232,98,26,0)');
    ctx.fillStyle = g1;
    ctx.fillRect(0, 0, 1080, 1920);

    const g2 = ctx.createRadialGradient(960, 1760, 0, 960, 1760, 380);
    g2.addColorStop(0, 'rgba(232,98,26,0.14)');
    g2.addColorStop(1, 'rgba(232,98,26,0)');
    ctx.fillStyle = g2;
    ctx.fillRect(0, 0, 1080, 1920);

    ctx.fillStyle = '#e8621a';
    ctx.fillRect(0, 0, 14, 1920);

    // ── ヘッダー ──
    const logoX = 100, logoY = 104, logoR = 42;
    ctx.beginPath();
    ctx.arc(logoX, logoY, logoR, 0, Math.PI * 2);
    ctx.fillStyle = '#e8621a';
    ctx.fill();

    ctx.fillStyle = '#ffffff';
    ctx.font = 'bold 44px serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText('忍', logoX, logoY + 2);

    ctx.fillStyle = '#ffffff';
    ctx.font = 'bold 40px "Noto Sans JP", sans-serif';
    ctx.textAlign = 'left';
    ctx.textBaseline = 'middle';
    ctx.fillText('ナルボル体験談', 162, logoY);

    ctx.beginPath();
    ctx.moveTo(60, 170);
    ctx.lineTo(1020, 170);
    ctx.strokeStyle = 'rgba(232,98,26,0.6)';
    ctx.lineWidth = 2;
    ctx.stroke();

    // ── キャッチフレーズ（コンパクト版） ──
    let curY = 200;
    ctx.fillStyle = '#e8621a';
    ctx.font = 'bold 54px "Noto Sans JP", sans-serif';
    ctx.textAlign = 'left';
    ctx.textBaseline = 'top';
    const catchN = drawWrapped(ctx, `「${catchphrase}」`, 60, curY, 960, 76);
    curY += catchN * 76 + 18;

    // 投稿者名 + タグ（横並び）
    ctx.fillStyle = 'rgba(255,255,255,0.65)';
    ctx.font = '500 36px "Noto Sans JP", sans-serif';
    ctx.textAlign = 'left';
    ctx.textBaseline = 'middle';
    ctx.fillText(`— ${displayName} さん`, 60, curY + 22);

    // タグ（右寄せ）
    const tagH = 50, tagR = 8;
    ctx.font = '500 28px "Noto Sans JP", sans-serif';
    const tw1 = ctx.measureText(firstSeries).width + 32;
    const tw2 = ctx.measureText(firstMedia).width + 32;
    drawPill(ctx, firstSeries, 1020 - tw2 - 12 - tw1, curY - 2, tw1, tagH, tagR, '#e8621a');
    drawPill(ctx, firstMedia, 1020 - tw2, curY - 2, tw2, tagH, tagR, '#3d3d72');
    curY += tagH + 32;

    // 区切り線
    ctx.beginPath();
    ctx.moveTo(60, curY);
    ctx.lineTo(1020, curY);
    ctx.strokeStyle = 'rgba(255,255,255,0.14)';
    ctx.lineWidth = 1;
    ctx.stroke();
    curY += 36;

    // ── 本文セクション ──
    const BODY_MAX = 1780; // フッター手前の下限
    const narrativeSections = mainStory
      ? [{ label: '体験談', text: mainStory }]
      : [
          { label: 'ハマるきっかけになったシーン', text: triggerScene },
          { label: '「あ、自分これ好きだ」と気づいた瞬間', text: realization },
          { label: '今のあなたとナルボルの関係', text: currentRelationship },
        ];
    const sections = [
      ...narrativeSections,
      { label: '特に好きなシーン・セリフ', text: favoriteScene },
      { label: 'こんな作品が観てみたい', text: futureWish },
      { label: '同じ作品を好きな人へ', text: message },
    ].filter(s => s.text);

    for (const section of sections) {
      if (curY > BODY_MAX) break;

      // セクション見出し（オレンジ、左端のマーク付き）
      ctx.fillStyle = '#e8621a';
      ctx.fillRect(60, curY, 6, 38);
      ctx.fillStyle = '#e8621a';
      ctx.font = 'bold 30px "Noto Sans JP", sans-serif';
      ctx.textAlign = 'left';
      ctx.textBaseline = 'top';
      const headN = drawWrapped(ctx, section.label, 80, curY, 940, 42);
      curY += headN * 42 + 14;

      // 本文（最大4行、超えたら末尾に…）
      const availLines = Math.floor(Math.min(4, (BODY_MAX - curY) / 50));
      if (availLines <= 0) break;
      ctx.fillStyle = 'rgba(255,255,255,0.88)';
      ctx.font = '400 34px "Noto Sans JP", sans-serif';
      ctx.textAlign = 'left';
      ctx.textBaseline = 'top';
      const bodyN = drawWrappedClamped(ctx, section.text, 60, curY, 960, 50, availLines);
      curY += bodyN * 50 + 44;
    }

    // ── フッター ──
    ctx.fillStyle = 'rgba(255,255,255,0.35)';
    ctx.font = '26px monospace';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'bottom';
    ctx.fillText('chachaTSUBAKI.github.io/naruboru-fan-site', 540, 1900);

    // ── シェア or ダウンロード ──
    canvas.toBlob(async (blob) => {
      const file = new File([blob], 'naruboru-story.png', { type: 'image/png' });
      try {
        if (navigator.canShare && navigator.canShare({ files: [file] })) {
          await navigator.share({ files: [file] });
        } else {
          downloadBlob(blob);
          showToast('画像をダウンロードしました。\nInstagramアプリのストーリーズから追加してください。');
        }
      } catch (e) {
        if (e.name !== 'AbortError') {
          downloadBlob(blob);
          showToast('画像をダウンロードしました。\nInstagramアプリのストーリーズから追加してください。');
        }
      } finally {
        btn.disabled = false;
        btn.innerHTML = originalHTML;
      }
    }, 'image/png');

  } catch (e) {
    console.error(e);
    btn.disabled = false;
    btn.innerHTML = originalHTML;
  }
});

// テキスト折り返し（行数を返す）
function drawWrapped(ctx, text, x, y, maxW, lineH) {
  const chars = [...text];
  let line = '';
  const lines = [];
  for (const ch of chars) {
    const test = line + ch;
    if (ctx.measureText(test).width > maxW && line !== '') {
      lines.push(line);
      line = ch;
    } else {
      line = test;
    }
  }
  if (line) lines.push(line);
  lines.forEach((l, i) => ctx.fillText(l, x, y + i * lineH));
  return lines.length;
}

// テキスト折り返し（最大行数制限 + 末尾に…）
function drawWrappedClamped(ctx, text, x, y, maxW, lineH, maxLines) {
  const chars = [...text];
  let line = '';
  const lines = [];
  for (const ch of chars) {
    const test = line + ch;
    if (ctx.measureText(test).width > maxW && line !== '') {
      lines.push(line);
      line = ch;
      if (lines.length >= maxLines) break;
    } else {
      line = test;
    }
  }
  if (line && lines.length < maxLines) lines.push(line);

  // 途中で切れた場合、最終行に…を付与
  const fullText = chars.join('');
  if (lines.join('').length < fullText.length && lines.length > 0) {
    let last = lines[lines.length - 1];
    while (last.length > 0 && ctx.measureText(last + '…').width > maxW) {
      last = last.slice(0, -1);
    }
    lines[lines.length - 1] = last + '…';
  }

  lines.forEach((l, i) => ctx.fillText(l, x, y + i * lineH));
  return lines.length;
}

function drawPill(ctx, text, x, y, w, h, r, bg) {
  ctx.beginPath();
  ctx.moveTo(x + r, y);
  ctx.lineTo(x + w - r, y);
  ctx.quadraticCurveTo(x + w, y, x + w, y + r);
  ctx.lineTo(x + w, y + h - r);
  ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
  ctx.lineTo(x + r, y + h);
  ctx.quadraticCurveTo(x, y + h, x, y + h - r);
  ctx.lineTo(x, y + r);
  ctx.quadraticCurveTo(x, y, x + r, y);
  ctx.closePath();
  ctx.fillStyle = bg;
  ctx.fill();
  ctx.fillStyle = '#ffffff';
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillText(text, x + w / 2, y + h / 2);
}

function downloadBlob(blob) {
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = 'naruboru-story.png';
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  setTimeout(() => URL.revokeObjectURL(url), 1000);
}

function showToast(message) {
  const toast = document.createElement('div');
  toast.className = 'share-toast';
  toast.textContent = message;
  document.body.appendChild(toast);
  requestAnimationFrame(() => {
    requestAnimationFrame(() => toast.classList.add('share-toast--visible'));
  });
  setTimeout(() => {
    toast.classList.remove('share-toast--visible');
    setTimeout(() => toast.remove(), 400);
  }, 5000);
}
</script>

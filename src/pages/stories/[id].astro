---
import BaseLayout from '../../layouts/BaseLayout.astro';
import stories from '../../data/stories.json';

export function getStaticPaths() {
  return (stories as any[]).map((story) => ({
    params: { id: story.id },
    props: { story },
  }));
}

const { story } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const siteUrl = 'https://chachaTSUBAKI.github.io/naruboru-fan-site';
const storyUrl = `${siteUrl}/stories/${story.id}`;
const shareText = `「${story.catchphrase}」\n${story.displayName}さんのナルボル体験談 #ナルボル体験談`;
const xShareUrl = `https://x.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(storyUrl)}`;
---

<BaseLayout
  title={story.displayName + 'の体験談'}
  description={`「${story.catchphrase}」— ${story.displayName}さんのナルボル体験談`}
>
  <article class="story-detail">
    <div class="story-detail-inner">

      <!-- パンくず -->
      <nav class="breadcrumb">
        <a href={`${base}/`}>ホーム</a> &rsaquo;
        <a href={`${base}/stories`}>体験談一覧</a> &rsaquo;
        <span>{story.displayName}</span>
      </nav>

      <!-- ヘッダー -->
      <header class="story-header">
        <div class="story-tags">
          <span class="tag tag-large">{story.firstSeries}</span>
          <span class="tag tag-large tag-media">{story.firstMedia}</span>
        </div>
        <blockquote class="story-catchphrase">
          &ldquo;{story.catchphrase}&rdquo;
        </blockquote>
        <div class="story-meta">
          <span class="story-name">{story.displayName}</span>
          {story.ageGroup && (
            <span class="story-meta-item">出会いは{story.ageGroup}</span>
          )}
          {story.favoriteCharacter && (
            <span class="story-meta-item">推し：{story.favoriteCharacter}</span>
          )}
          <span class="story-meta-item story-date">
            {new Date(story.publishedAt).toLocaleDateString('ja-JP', {
              year: 'numeric', month: 'long', day: 'numeric'
            })}
          </span>
        </div>
      </header>

      <!-- 画像（あれば） -->
      {story.imageUrl && (
        <div class="story-image">
          <img src={story.imageUrl} alt={story.imageCaption ?? story.displayName + 'の投稿画像'} />
          {story.imageCaption && <p class="story-image-caption">{story.imageCaption}</p>}
        </div>
      )}

      <!-- 本文 -->
      <div class="story-body">
        {story.triggerScene && (
          <section class="story-section">
            <h2>ハマるきっかけになったシーン</h2>
            <p>{story.triggerScene}</p>
          </section>
        )}

        {story.realization && (
          <section class="story-section">
            <h2>「あ、自分これ好きだ」と気づいた瞬間</h2>
            <p>{story.realization}</p>
          </section>
        )}

        {story.currentRelationship && (
          <section class="story-section">
            <h2>今のあなたとナルボルの関係</h2>
            <p>{story.currentRelationship}</p>
          </section>
        )}

        {story.message && (
          <section class="story-message">
            <p class="message-label">同じ作品を好きな人へ</p>
            <blockquote class="message-quote">&ldquo;{story.message}&rdquo;</blockquote>
          </section>
        )}
      </div>

      <!-- シェアボタン -->
      <div class="story-share">
        <p class="story-share-label">この体験談をシェアする</p>
        <a href={xShareUrl} target="_blank" rel="noopener noreferrer" class="btn btn-x-share">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.742l7.732-8.857L1.555 2.25H8.08l4.27 5.646L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
          </svg>
          Xでシェア
        </a>
        <button type="button" id="ig-share-btn" class="btn btn-ig-share">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <circle cx="12" cy="12" r="5"/>
            <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" stroke="none"/>
          </svg>
          Instagramストーリーズ
        </button>
      </div>

      <!-- ナビゲーション -->
      <nav class="story-nav">
        <a href={`${base}/stories`} class="btn btn-outline">&larr; 一覧に戻る</a>
        <a href={`${base}/submit`} class="btn btn-primary">あなたの体験談を投稿する</a>
      </nav>

    </div>
  </article>
</BaseLayout>

<script define:vars={{ catchphrase: story.catchphrase, displayName: story.displayName, storyUrl, firstSeries: story.firstSeries, firstMedia: story.firstMedia }}>
const btn = document.getElementById('ig-share-btn');
const originalHTML = btn.innerHTML;

btn.addEventListener('click', async () => {
  btn.disabled = true;
  btn.textContent = '画像を生成中…';

  try {
    await Promise.allSettled([
      document.fonts.load('bold 72px "Noto Sans JP"'),
      document.fonts.load('500 40px "Noto Sans JP"'),
      document.fonts.load('400 32px "Noto Sans JP"'),
    ]);

    const canvas = document.createElement('canvas');
    canvas.width = 1080;
    canvas.height = 1920;
    const ctx = canvas.getContext('2d');

    // ── 背景 ──
    ctx.fillStyle = '#1a1a2e';
    ctx.fillRect(0, 0, 1080, 1920);

    // オレンジのグラデーション装飾（上左）
    const g1 = ctx.createRadialGradient(180, 480, 0, 180, 480, 640);
    g1.addColorStop(0, 'rgba(232,98,26,0.28)');
    g1.addColorStop(1, 'rgba(232,98,26,0)');
    ctx.fillStyle = g1;
    ctx.fillRect(0, 0, 1080, 1920);

    // グラデーション装飾（下右）
    const g2 = ctx.createRadialGradient(920, 1680, 0, 920, 1680, 420);
    g2.addColorStop(0, 'rgba(232,98,26,0.18)');
    g2.addColorStop(1, 'rgba(232,98,26,0)');
    ctx.fillStyle = g2;
    ctx.fillRect(0, 0, 1080, 1920);

    // 左アクセントバー
    ctx.fillStyle = '#e8621a';
    ctx.fillRect(0, 0, 14, 1920);

    // ── ヘッダー ──
    // 忍マーク
    ctx.beginPath();
    ctx.arc(120, 176, 58, 0, Math.PI * 2);
    ctx.fillStyle = '#e8621a';
    ctx.fill();

    ctx.fillStyle = '#ffffff';
    ctx.font = 'bold 58px serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText('忍', 120, 178);

    // サイト名
    ctx.fillStyle = '#ffffff';
    ctx.font = 'bold 46px "Noto Sans JP", sans-serif';
    ctx.textAlign = 'left';
    ctx.textBaseline = 'middle';
    ctx.fillText('ナルボル体験談', 204, 176);

    // ヘッダー区切り線
    ctx.beginPath();
    ctx.moveTo(80, 290);
    ctx.lineTo(1000, 290);
    ctx.strokeStyle = 'rgba(232,98,26,0.55)';
    ctx.lineWidth = 2;
    ctx.stroke();

    // ── 引用デコレーション ──
    ctx.fillStyle = 'rgba(232,98,26,0.45)';
    ctx.font = 'bold 220px Georgia, serif';
    ctx.textAlign = 'left';
    ctx.textBaseline = 'top';
    ctx.fillText('\u201C', 56, 290);

    // ── キャッチフレーズ ──
    ctx.fillStyle = '#ffffff';
    ctx.font = 'bold 72px "Noto Sans JP", sans-serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'top';
    const catchLines = drawWrappedText(ctx, catchphrase, 540, 530, 880, 104);
    const afterCatch = 530 + catchLines * 104;

    // 閉じ引用符（小さめ）
    ctx.fillStyle = 'rgba(232,98,26,0.35)';
    ctx.font = 'bold 120px Georgia, serif';
    ctx.textAlign = 'right';
    ctx.textBaseline = 'top';
    ctx.fillText('\u201D', 1020, afterCatch - 30);

    // ── 投稿者名 ──
    ctx.fillStyle = 'rgba(255,255,255,0.72)';
    ctx.font = '500 44px "Noto Sans JP", sans-serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'top';
    ctx.fillText(`— ${displayName} さん`, 540, afterCatch + 70);

    // ── タグ ──
    const tagY = afterCatch + 160;
    const tagH = 62;
    const tagR = 10;
    ctx.font = '500 32px "Noto Sans JP", sans-serif';
    const tw1 = ctx.measureText(firstSeries).width;
    const tw2 = ctx.measureText(firstMedia).width;
    const tpx = 22;
    const tgap = 20;
    const totalTW = (tw1 + tpx * 2) + tgap + (tw2 + tpx * 2);
    const tagStartX = (1080 - totalTW) / 2;

    drawPill(ctx, firstSeries, tagStartX, tagY, tw1 + tpx * 2, tagH, tagR, '#e8621a');
    drawPill(ctx, firstMedia, tagStartX + tw1 + tpx * 2 + tgap, tagY, tw2 + tpx * 2, tagH, tagR, '#3d3d72');

    // ── ボトム区切り ──
    const divY = Math.min(tagY + 130, 1560);
    ctx.beginPath();
    ctx.moveTo(80, divY);
    ctx.lineTo(1000, divY);
    ctx.strokeStyle = 'rgba(255,255,255,0.12)';
    ctx.lineWidth = 1;
    ctx.stroke();

    // サブコピー
    ctx.fillStyle = 'rgba(255,255,255,0.55)';
    ctx.font = '400 34px "Noto Sans JP", sans-serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'bottom';
    ctx.fillText('ナルボルファンの体験談を読む', 540, 1790);

    // URL
    ctx.fillStyle = 'rgba(255,255,255,0.35)';
    ctx.font = '28px monospace';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'bottom';
    ctx.fillText('chachaTSUBAKI.github.io/naruboru-fan-site', 540, 1870);

    // ── シェア or ダウンロード ──
    canvas.toBlob(async (blob) => {
      const file = new File([blob], 'naruboru-story.png', { type: 'image/png' });
      try {
        if (navigator.canShare && navigator.canShare({ files: [file] })) {
          await navigator.share({ files: [file] });
        } else {
          downloadBlob(blob);
        }
      } catch (e) {
        if (e.name !== 'AbortError') downloadBlob(blob);
      } finally {
        btn.disabled = false;
        btn.innerHTML = originalHTML;
      }
    }, 'image/png');

  } catch (e) {
    console.error(e);
    btn.disabled = false;
    btn.innerHTML = originalHTML;
  }
});

function drawWrappedText(ctx, text, cx, y, maxW, lineH) {
  const chars = [...text];
  let line = '';
  const lines = [];
  for (const ch of chars) {
    const test = line + ch;
    if (ctx.measureText(test).width > maxW && line !== '') {
      lines.push(line);
      line = ch;
    } else {
      line = test;
    }
  }
  if (line) lines.push(line);
  lines.forEach((l, i) => ctx.fillText(l, cx, y + i * lineH));
  return lines.length;
}

function drawPill(ctx, text, x, y, w, h, r, bg) {
  ctx.beginPath();
  ctx.moveTo(x + r, y);
  ctx.lineTo(x + w - r, y);
  ctx.quadraticCurveTo(x + w, y, x + w, y + r);
  ctx.lineTo(x + w, y + h - r);
  ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
  ctx.lineTo(x + r, y + h);
  ctx.quadraticCurveTo(x, y + h, x, y + h - r);
  ctx.lineTo(x, y + r);
  ctx.quadraticCurveTo(x, y, x + r, y);
  ctx.closePath();
  ctx.fillStyle = bg;
  ctx.fill();
  ctx.fillStyle = '#ffffff';
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillText(text, x + w / 2, y + h / 2);
}

function downloadBlob(blob) {
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = 'naruboru-story.png';
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  setTimeout(() => URL.revokeObjectURL(url), 1000);
}
</script>

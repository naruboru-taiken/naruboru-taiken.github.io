---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StoryCard from '../../components/StoryCard.astro';
import stories from '../../data/stories.json';
import affiliateItems from '../../data/affiliate-items.json';
import { getStoryText } from '../../i18n/ui';

export function getStaticPaths() {
  const list = stories as any[];
  return list.map((story, index) => ({
    params: { id: story.id },
    props: {
      story,
      prevStory: index > 0 ? { id: list[index-1].id, displayName: list[index-1].displayName } : null,
      nextStory: index < list.length - 1 ? { id: list[index+1].id, displayName: list[index+1].displayName } : null,
      allIds: list.map(s => s.id),
    },
  }));
}

const { story, prevStory, nextStory, allIds } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const mainStory = getStoryText(story, 'ja', 'mainStory');
const triggerScene = getStoryText(story, 'ja', 'triggerScene');
const realization = getStoryText(story, 'ja', 'realization');
const currentRelationship = getStoryText(story, 'ja', 'currentRelationship');
const favoriteScene = getStoryText(story, 'ja', 'favoriteScene');
const futureWish = getStoryText(story, 'ja', 'futureWish');
const catchphrase = getStoryText(story, 'ja', 'catchphrase');
const favoriteCharacter = getStoryText(story, 'ja', 'favoriteCharacter');
const country = getStoryText(story, 'ja', 'country');
const isTranslatedToJa = (story as any).sourceLang && (story as any).sourceLang !== 'ja';

function truncate(text: string, max = 60) {
  return text.length > max ? text.slice(0, max) + '…' : text;
}
const displayCatchphrase =
  catchphrase ||
  (mainStory ? truncate(mainStory) : null) ||
  (triggerScene ? truncate(triggerScene) : null) ||
  '';

// 関連体験談スコアリング
function getRelatedStories(current: any, all: any[], count = 3) {
  return all
    .filter(s => s.id !== current.id)
    .map(s => {
      let score = 0;
      if (s.favoriteCharacter && current.favoriteCharacter &&
          s.favoriteCharacter === current.favoriteCharacter) score += 3;
      if (s.firstSeries && s.firstSeries === current.firstSeries) score += 2;
      if (s.ageGroup && s.ageGroup === current.ageGroup) score += 1;
      if (s.firstMedia && s.firstMedia === current.firstMedia) score += 1;
      return { story: s, score };
    })
    .sort((a, b) =>
      b.score !== a.score
        ? b.score - a.score
        : new Date(b.story.publishedAt).getTime() - new Date(a.story.publishedAt).getTime()
    )
    .slice(0, count)
    .map(x => x.story);
}
const relatedStories = getRelatedStories(story, stories as any[]);

// アフィリエイトアイテムのマッチング
const matchedAffiliateItems = (affiliateItems as any[]).filter(item => {
  if (!item.active) return false;
  const seriesMatch = item.matchSeries.length === 0 || item.matchSeries.includes(story.firstSeries);
  const charaMatch = item.matchCharacters.length === 0 || item.matchCharacters.includes(story.favoriteCharacter);
  return seriesMatch && charaMatch;
}).slice(0, 3);

const siteUrl = 'https://naruboru-taiken.github.io';
const storyUrl = `${siteUrl}/stories/${story.id}`;
const ogpImageUrl = `${siteUrl}/ogp/${story.id}.png`;
const shareText = `${story.displayName}さんのナルボル体験談${story.favoriteCharacter ? `（推し：${story.favoriteCharacter}）` : ''}\nあなたのハマった瞬間も、ぜひ投稿してみてください #ナルボル体験談`;
const xShareUrl = `https://x.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(storyUrl)}`;
---

<BaseLayout
  title={story.displayName + 'の体験談'}
  description={`「${story.catchphrase}」— ${story.displayName}さんのナルボル体験談`}
  ogImage={ogpImageUrl}
  lang="ja"
  pagePath={`/stories/${story.id}`}
>
  <article class="story-detail">
    <div class="story-detail-inner">

      <!-- パンくず -->
      <nav class="breadcrumb">
        <a href={`${base}/`}>ホーム</a> &rsaquo;
        <a href={`${base}/stories`}>体験談一覧</a> &rsaquo;
        <span>{story.displayName}</span>
      </nav>

      <!-- ヘッダー -->
      <header class="story-header">
        <div class="story-tags">
          {story.firstSeries && <span class="tag tag-large">{story.firstSeries}</span>}
          {story.firstMedia && <span class="tag tag-large tag-media">{story.firstMedia}</span>}
        </div>
        <blockquote class="story-catchphrase">
          &ldquo;{displayCatchphrase}&rdquo;
        </blockquote>
        <div class="story-meta">
          <span class="story-name">{story.displayName}</span>
          {story.ageGroup && (
            <span class="story-meta-item">出会いは{story.ageGroup}</span>
          )}
          {favoriteCharacter && (
            <span class="story-meta-item">推し：{favoriteCharacter}</span>
          )}
          {country && (
            <span class="story-meta-item">居住地：{country}</span>
          )}
          <span class="story-meta-item story-date">
            {new Date(story.publishedAt).toLocaleDateString('ja-JP', {
              year: 'numeric', month: 'long', day: 'numeric'
            })}
          </span>
        </div>
        {isTranslatedToJa && (
          <p class="translation-notice translation-notice--translated">※ この体験談は海外からの投稿を日本語に翻訳して掲載しています。</p>
        )}
      </header>

      <!-- 画像（あれば） -->
      {story.imageUrl && (
        <div class="story-image">
          <img src={story.imageUrl} alt={story.imageCaption ?? story.displayName + 'の投稿画像'} />
          {story.imageCaption && <p class="story-image-caption">{story.imageCaption}</p>}
        </div>
      )}

      <!-- 本文 -->
      <div class="story-body">
        {mainStory ? (
          <section class="story-section">
            <h2>体験談</h2>
            <p>{mainStory}</p>
          </section>
        ) : (
          <>
            {triggerScene && (
              <section class="story-section">
                <h2>ハマるきっかけになったシーン</h2>
                <p>{triggerScene}</p>
              </section>
            )}

            {realization && (
              <section class="story-section">
                <h2>「あ、自分これ好きだ」と気づいた瞬間</h2>
                <p>{realization}</p>
              </section>
            )}

            {currentRelationship && (
              <section class="story-section">
                <h2>今のあなたとナルボルの関係</h2>
                <p>{currentRelationship}</p>
              </section>
            )}
          </>
        )}

        {favoriteScene && (
          <section class="story-section">
            <h2>特に好きなシーン・セリフ</h2>
            <p>{favoriteScene}</p>
          </section>
        )}

        {futureWish && (
          <section class="story-section story-section--wish">
            <h2>こんな作品が観てみたい</h2>
            <p>{futureWish}</p>
          </section>
        )}

        {getStoryText(story, 'ja', 'message') && (
          <section class="story-message">
            <p class="message-label">ひとこと</p>
            <blockquote class="message-quote">&ldquo;{getStoryText(story, 'ja', 'message')}&rdquo;</blockquote>
          </section>
        )}
      </div>

      <!-- アクションバー（リアクション＋シェア統合） -->
      <div class="story-actions">
        <button type="button" id="like-btn" class="action-btn action-btn--like" aria-pressed="false">
          <span class="action-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <path d="M12 21s-7-4.4-9.2-8.2C.6 9 2.1 6 5.1 5.2c1.7-.5 3.6.1 4.8 1.5 1.2-1.4 3.1-2 4.8-1.5 3 .8 4.5 3.8 2.3 7.6C19 16.6 12 21 12 21z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
            </svg>
          </span>
          <span class="action-label">わかる！</span>
        </button>
        <button type="button" id="fav-btn" class="action-btn action-btn--fav" aria-pressed="false">
          <span class="action-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <path d="M12 21s-7-4.4-9.2-8.2C.6 9 2.1 6 5.1 5.2c1.7-.5 3.6.1 4.8 1.5 1.2-1.4 3.1-2 4.8-1.5 3 .8 4.5 3.8 2.3 7.6C19 16.6 12 21 12 21z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
            </svg>
          </span>
          <span class="action-label">保存</span>
        </button>
        <a href={xShareUrl} target="_blank" rel="noopener noreferrer" class="action-btn action-btn--x">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.742l7.732-8.857L1.555 2.25H8.08l4.27 5.646L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
          </svg>
          <span class="action-label">X</span>
        </a>
        <button type="button" id="ig-share-btn" class="action-btn action-btn--ig">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <circle cx="12" cy="12" r="5"/>
            <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" stroke="none"/>
          </svg>
          <span class="action-label">IG</span>
        </button>
      </div>

      <!-- わかる！CTA バブル -->
      <div id="like-cta" class="like-cta" hidden aria-live="polite">
        <p class="like-cta-text">あなたのナルボル体験談も、ここに残しませんか。</p>
        <a href={`${base}/submit`} class="like-cta-link">投稿する →</a>
        <button type="button" id="like-cta-close" class="like-cta-close" aria-label="閉じる">×</button>
      </div>

      <!-- アフィリエイトリンク -->
      {matchedAffiliateItems.length > 0 && (
        <aside class="affiliate-section">
          <p class="affiliate-label">関連グッズ・作品を探す</p>
          <ul class="affiliate-list">
            {matchedAffiliateItems.map((item: any) => (
              <li>
                <a
                  href={item.url}
                  target="_blank"
                  rel="noopener noreferrer sponsored"
                  class={`affiliate-link affiliate-${item.shopType}`}
                >
                  <span class="affiliate-shop">{item.shopName}</span>
                  <span class="affiliate-title">{item.title}</span>
                  <span class="affiliate-arrow">→</span>
                </a>
              </li>
            ))}
          </ul>
        </aside>
      )}

      <!-- 関連体験談 -->
      {relatedStories.length > 0 && (
        <section class="related-stories">
          <h2 class="related-stories-title">こんな体験談も</h2>
          <div class="related-stories-grid">
            {relatedStories.map(s => <StoryCard story={s} />)}
          </div>
        </section>
      )}

      <!-- 前後ナビ -->
      <nav class="story-prev-next" aria-label="前後の体験談">
        {prevStory ? (
          <a href={`${base}/stories/${prevStory.id}`} class="prev-next-link prev-link">
            <span class="prev-next-arrow">←</span>
            <span class="prev-next-name">{prevStory.displayName}</span>
          </a>
        ) : <span />}
        {nextStory ? (
          <a href={`${base}/stories/${nextStory.id}`} class="prev-next-link next-link">
            <span class="prev-next-name">{nextStory.displayName}</span>
            <span class="prev-next-arrow">→</span>
          </a>
        ) : <span />}
      </nav>

      <!-- 投稿CTA -->
      <div class="story-cta">
        <a href={`${base}/submit`} class="btn btn-primary btn-large">あなたの体験談を投稿する</a>
        <div class="story-cta-sub">
          <button type="button" id="random-btn" class="btn-text-link">ランダムに読む</button>
          <a href={`${base}/stories`} class="btn-text-link">← 一覧に戻る</a>
        </div>
      </div>

    </div>
  </article>
</BaseLayout>

<script define:vars={{
  catchphrase: displayCatchphrase,
  displayName: story.displayName,
  storyUrl,
  firstSeries: story.firstSeries,
  firstMedia: story.firstMedia,
  mainStory: mainStory ?? null,
  triggerScene: triggerScene ?? null,
  realization: realization ?? null,
  currentRelationship: currentRelationship ?? null,
  favoriteScene: favoriteScene ?? null,
  futureWish: futureWish ?? null,
  message: story.message ?? null,
  storyId: story.id,
  allIds,
  base,
}}>
// ── 既読記録 ──
const readList = JSON.parse(localStorage.getItem('naruboru-read') || '[]');
if (!readList.includes(storyId)) {
  readList.push(storyId);
  localStorage.setItem('naruboru-read', JSON.stringify(readList));
}

// ── お気に入りボタン ──
const favBtn = document.getElementById('fav-btn');
const favList = () => JSON.parse(localStorage.getItem('naruboru-favorites') || '[]');
function updateFavBtn() {
  const isFav = favList().includes(storyId);
  favBtn.querySelector('.action-label').textContent = isFav ? '保存済み' : '保存';
  favBtn.classList.toggle('favorited', isFav);
  favBtn.setAttribute('aria-pressed', String(isFav));
  favBtn.setAttribute('aria-label', isFav ? '保存済み（解除）' : '保存');
}
updateFavBtn();
favBtn?.addEventListener('click', () => {
  const list = favList();
  const idx = list.indexOf(storyId);
  if (idx === -1) list.push(storyId); else list.splice(idx, 1);
  localStorage.setItem('naruboru-favorites', JSON.stringify(list));
  updateFavBtn();
});

// ── わかる！ボタン ──
const likeBtn = document.getElementById('like-btn');
const likeList = () => JSON.parse(localStorage.getItem('naruboru-likes') || '[]');
function updateLikeBtn() {
  const isLiked = likeList().includes(storyId);
  likeBtn.querySelector('.action-label').textContent = isLiked ? 'わかった！' : 'わかる！';
  likeBtn.classList.toggle('liked', isLiked);
  likeBtn.setAttribute('aria-pressed', String(isLiked));
}
updateLikeBtn();

// ── わかる！CTA バブル ──
let ctaTimer: ReturnType<typeof setTimeout> | null = null;

function showLikeCta() {
  const cta = document.getElementById('like-cta');
  if (!cta) return;
  cta.removeAttribute('hidden');
  requestAnimationFrame(() => {
    requestAnimationFrame(() => cta.classList.add('like-cta--visible'));
  });
  ctaTimer = setTimeout(hideLikeCta, 6000);
}

function hideLikeCta() {
  const cta = document.getElementById('like-cta');
  if (!cta) return;
  cta.classList.remove('like-cta--visible');
  setTimeout(() => cta.setAttribute('hidden', ''), 300);
  if (ctaTimer) { clearTimeout(ctaTimer); ctaTimer = null; }
}

document.getElementById('like-cta-close')?.addEventListener('click', hideLikeCta);

likeBtn?.addEventListener('click', () => {
  const list = likeList();
  const idx = list.indexOf(storyId);
  const wasLiked = idx !== -1;
  if (idx === -1) list.push(storyId); else list.splice(idx, 1);
  localStorage.setItem('naruboru-likes', JSON.stringify(list));
  updateLikeBtn();
  // 初めてわかる！を押した時だけCTAを表示
  if (!wasLiked) showLikeCta();
});

// ── ランダムボタン ──
document.getElementById('random-btn')?.addEventListener('click', () => {
  const others = allIds.filter(id => id !== storyId);
  if (others.length === 0) return;
  const randomId = others[Math.floor(Math.random() * others.length)];
  window.location.href = `${base}/stories/${randomId}`;
});

const btn = document.getElementById('ig-share-btn');
const originalHTML = btn.innerHTML;

btn.addEventListener('click', async () => {
  btn.disabled = true;
  btn.textContent = '画像を生成中…';

  try {
    // CSSで宣言されたフォント（Noto Sans JP）がcanvasで使えるまで待機
    await document.fonts.ready;

    const canvas = document.createElement('canvas');
    canvas.width = 1080;
    canvas.height = 1920;
    const ctx = canvas.getContext('2d');

    // ── 背景 ──
    ctx.fillStyle = '#1a1a2e';
    ctx.fillRect(0, 0, 1080, 1920);

    const g1 = ctx.createRadialGradient(160, 360, 0, 160, 360, 560);
    g1.addColorStop(0, 'rgba(232,98,26,0.22)');
    g1.addColorStop(1, 'rgba(232,98,26,0)');
    ctx.fillStyle = g1;
    ctx.fillRect(0, 0, 1080, 1920);

    const g2 = ctx.createRadialGradient(960, 1760, 0, 960, 1760, 380);
    g2.addColorStop(0, 'rgba(232,98,26,0.14)');
    g2.addColorStop(1, 'rgba(232,98,26,0)');
    ctx.fillStyle = g2;
    ctx.fillRect(0, 0, 1080, 1920);

    ctx.fillStyle = '#e8621a';
    ctx.fillRect(0, 0, 14, 1920);

    // ── ヘッダー ──
    const logoX = 100, logoY = 104, logoR = 42;
    ctx.beginPath();
    ctx.arc(logoX, logoY, logoR, 0, Math.PI * 2);
    ctx.fillStyle = '#e8621a';
    ctx.fill();

    ctx.fillStyle = '#ffffff';
    ctx.font = 'bold 44px serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText('忍', logoX, logoY + 2);

    ctx.fillStyle = '#ffffff';
    ctx.font = 'bold 40px "Noto Sans JP", sans-serif';
    ctx.textAlign = 'left';
    ctx.textBaseline = 'middle';
    ctx.fillText('ナルボル体験談', 162, logoY);

    ctx.beginPath();
    ctx.moveTo(60, 170);
    ctx.lineTo(1020, 170);
    ctx.strokeStyle = 'rgba(232,98,26,0.6)';
    ctx.lineWidth = 2;
    ctx.stroke();

    // ── キャッチフレーズ（コンパクト版） ──
    let curY = 200;
    ctx.fillStyle = '#e8621a';
    ctx.font = 'bold 54px "Noto Sans JP", sans-serif';
    ctx.textAlign = 'left';
    ctx.textBaseline = 'top';
    const catchN = drawWrapped(ctx, `「${catchphrase}」`, 60, curY, 960, 76);
    curY += catchN * 76 + 18;

    // 投稿者名 + タグ（横並び）
    ctx.fillStyle = 'rgba(255,255,255,0.65)';
    ctx.font = '500 36px "Noto Sans JP", sans-serif';
    ctx.textAlign = 'left';
    ctx.textBaseline = 'middle';
    ctx.fillText(`— ${displayName} さん`, 60, curY + 22);

    // タグ（右寄せ）
    const tagH = 50, tagR = 8;
    ctx.font = '500 28px "Noto Sans JP", sans-serif';
    const tw1 = ctx.measureText(firstSeries).width + 32;
    const tw2 = ctx.measureText(firstMedia).width + 32;
    drawPill(ctx, firstSeries, 1020 - tw2 - 12 - tw1, curY - 2, tw1, tagH, tagR, '#e8621a');
    drawPill(ctx, firstMedia, 1020 - tw2, curY - 2, tw2, tagH, tagR, '#3d3d72');
    curY += tagH + 32;

    // 区切り線
    ctx.beginPath();
    ctx.moveTo(60, curY);
    ctx.lineTo(1020, curY);
    ctx.strokeStyle = 'rgba(255,255,255,0.14)';
    ctx.lineWidth = 1;
    ctx.stroke();
    curY += 36;

    // ── 本文セクション ──
    const BODY_MAX = 1780; // フッター手前の下限
    const narrativeSections = mainStory
      ? [{ label: '体験談', text: mainStory }]
      : [
          { label: 'ハマるきっかけになったシーン', text: triggerScene },
          { label: '「あ、自分これ好きだ」と気づいた瞬間', text: realization },
          { label: '今のあなたとナルボルの関係', text: currentRelationship },
        ];
    const sections = [
      ...narrativeSections,
      { label: '特に好きなシーン・セリフ', text: favoriteScene },
      { label: 'こんな作品が観てみたい', text: futureWish },
      { label: '同じ作品を好きな人へ', text: message },
    ].filter(s => s.text);

    for (let si = 0; si < sections.length; si++) {
      const section = sections[si];
      if (curY > BODY_MAX) break;

      // セクション見出し（オレンジ、左端のマーク付き）
      ctx.fillStyle = '#e8621a';
      ctx.fillRect(60, curY, 6, 38);
      ctx.fillStyle = '#e8621a';
      ctx.font = 'bold 30px "Noto Sans JP", sans-serif';
      ctx.textAlign = 'left';
      ctx.textBaseline = 'top';
      const headN = drawWrapped(ctx, section.label, 80, curY, 940, 42);
      curY += headN * 42 + 14;

      // 残りセクション数で空きスペースを均等割り、最低2行は確保
      const remainingSections = sections.length - si;
      const availLines = Math.max(2, Math.floor((BODY_MAX - curY) / 50 / remainingSections));
      if (availLines <= 0) break;
      ctx.fillStyle = 'rgba(255,255,255,0.88)';
      ctx.font = '400 34px "Noto Sans JP", sans-serif';
      ctx.textAlign = 'left';
      ctx.textBaseline = 'top';
      const bodyN = drawWrappedClamped(ctx, section.text, 60, curY, 960, 50, availLines);
      curY += bodyN * 50 + 44;
    }

    // ── フッター ──
    ctx.fillStyle = 'rgba(255,255,255,0.35)';
    ctx.font = '26px monospace';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'bottom';
    ctx.fillText('naruboru-taiken.github.io', 540, 1900);

    // ── シェア or ダウンロード ──
    canvas.toBlob(async (blob) => {
      const file = new File([blob], 'naruboru-story.png', { type: 'image/png' });
      try {
        if (navigator.canShare && navigator.canShare({ files: [file] })) {
          await navigator.share({ files: [file] });
        } else {
          downloadBlob(blob);
          showToast('画像をダウンロードしました。\nInstagramアプリのストーリーズから追加してください。');
        }
      } catch (e) {
        if (e.name !== 'AbortError') {
          downloadBlob(blob);
          showToast('画像をダウンロードしました。\nInstagramアプリのストーリーズから追加してください。');
        }
      } finally {
        btn.disabled = false;
        btn.innerHTML = originalHTML;
      }
    }, 'image/png');

  } catch (e) {
    console.error(e);
    btn.disabled = false;
    btn.innerHTML = originalHTML;
  }
});

// テキスト折り返し（行数を返す）
function drawWrapped(ctx, text, x, y, maxW, lineH) {
  const chars = [...text];
  let line = '';
  const lines = [];
  for (const ch of chars) {
    const test = line + ch;
    if (ctx.measureText(test).width > maxW && line !== '') {
      lines.push(line);
      line = ch;
    } else {
      line = test;
    }
  }
  if (line) lines.push(line);
  lines.forEach((l, i) => ctx.fillText(l, x, y + i * lineH));
  return lines.length;
}

// テキスト折り返し（最大行数制限 + 末尾に… + \n改行対応）
function drawWrappedClamped(ctx, text, x, y, maxW, lineH, maxLines) {
  // \n で段落分割し、各段落を幅で折り返して全行リストを作る
  const allLines = [];
  for (const para of text.split('\n')) {
    if (para.trim() === '') continue; // 空行はスペース節約のためスキップ
    const chars = [...para];
    let line = '';
    for (const ch of chars) {
      const test = line + ch;
      if (ctx.measureText(test).width > maxW && line !== '') {
        allLines.push(line);
        line = ch;
      } else {
        line = test;
      }
    }
    if (line) allLines.push(line);
  }

  const truncated = allLines.length > maxLines;
  const lines = allLines.slice(0, maxLines);

  // 途中で切れた場合、最終行に…を付与
  if (truncated && lines.length > 0) {
    let last = lines[lines.length - 1];
    while (last.length > 0 && ctx.measureText(last + '…').width > maxW) {
      last = last.slice(0, -1);
    }
    lines[lines.length - 1] = last + '…';
  }

  lines.forEach((l, i) => ctx.fillText(l, x, y + i * lineH));
  return lines.length;
}

function drawPill(ctx, text, x, y, w, h, r, bg) {
  ctx.beginPath();
  ctx.moveTo(x + r, y);
  ctx.lineTo(x + w - r, y);
  ctx.quadraticCurveTo(x + w, y, x + w, y + r);
  ctx.lineTo(x + w, y + h - r);
  ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
  ctx.lineTo(x + r, y + h);
  ctx.quadraticCurveTo(x, y + h, x, y + h - r);
  ctx.lineTo(x, y + r);
  ctx.quadraticCurveTo(x, y, x + r, y);
  ctx.closePath();
  ctx.fillStyle = bg;
  ctx.fill();
  ctx.fillStyle = '#ffffff';
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillText(text, x + w / 2, y + h / 2);
}

function downloadBlob(blob) {
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = 'naruboru-story.png';
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  setTimeout(() => URL.revokeObjectURL(url), 1000);
}

function showToast(message) {
  const toast = document.createElement('div');
  toast.className = 'share-toast';
  toast.textContent = message;
  document.body.appendChild(toast);
  requestAnimationFrame(() => {
    requestAnimationFrame(() => toast.classList.add('share-toast--visible'));
  });
  setTimeout(() => {
    toast.classList.remove('share-toast--visible');
    setTimeout(() => toast.remove(), 400);
  }, 5000);
}
</script>

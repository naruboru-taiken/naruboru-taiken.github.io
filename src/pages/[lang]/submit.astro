---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SUPPORTED_LANGS, useTranslations, isSupportedLang } from '../../i18n/ui';
import type { SupportedLang } from '../../i18n/ui';

export function getStaticPaths() {
  return SUPPORTED_LANGS.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: SupportedLang };
if (!isSupportedLang(lang)) return Astro.redirect('/submit');

const t = useTranslations(lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// 言語別専用フォーム（未設定の言語は日本語フォームにフォールバック）
const FORM_URL_MAP: Partial<Record<SupportedLang, string>> = {
  en: 'https://docs.google.com/forms/d/e/1FAIpQLScpvFxLBG4KwVaaaNkhtrd-8GAmVLANlvWluuUqHycszfdHcA/viewform?embedded=true',
  fr: 'https://docs.google.com/forms/d/e/1FAIpQLSee027-4QeJHIBrXj-HOUOIFqXFwWOyJcBiTLGX94unIPo3bA/viewform?embedded=true',
  ar: 'https://docs.google.com/forms/d/e/1FAIpQLSef2MXA7phgG-X3bjeuMuoORxrUnHphNDW-IqSN-BxnFevyzw/viewform?embedded=true',
  es: 'https://docs.google.com/forms/d/e/1FAIpQLSdm0_RXuty7sHhkLeo_90hATdxtfBEGPNlAjFiLlMFOrTmYIA/viewform?embedded=true',
  pt: 'https://docs.google.com/forms/d/e/1FAIpQLSfNuQe9ND73EoyHSXzfvT7zb6JLw84mMHA2vleZmSJwQrkJaw/viewform?embedded=true',
  zh: 'https://docs.google.com/forms/d/e/1FAIpQLSctCczpJ4o4Z4NaVwsK0G-YIxylw-OXg-S2zpbOrAxBBGaG9w/viewform?embedded=true',
  ko: 'https://docs.google.com/forms/d/1d0whf5dlMyS0ZqTLFbxDByu9clpEQSPZCVN9Kz8sCdU/viewform?embedded=true',
};
const FORM_LANG_MAP: Record<SupportedLang, string> = {
  en: 'en', fr: 'fr', ar: 'ar', es: 'es', pt: 'pt-BR', zh: 'zh-CN', ko: 'ko',
};
const FORM_URL = FORM_URL_MAP[lang]
  ?? `https://docs.google.com/forms/d/e/1FAIpQLSc5haprqYIM3MX0FdsuPVZinmbA4xPljPETYs1ewAfL9EW59Q/viewform?embedded=true&hl=${FORM_LANG_MAP[lang]}`;

const notices = {
  en: {
    notice: 'The submission form is in Japanese. Please fill it out in Japanese.',
    checklist_title: 'Before you submit',
    checklist: [
      { icon: '📋', text: 'Have you read the', link_text: 'submission guidelines', link_path: '/guidelines' },
      { icon: '🔒', text: 'Do not include personal information (real name, address, etc.). Your X ID is for contact only and will not be published.' },
    ],
    thanks_title: 'Submission received!',
    thanks_desc: 'Thank you. After review, your story will be published within a few days to a week.',
    thanks_x: 'We\'ll notify you via our X account',
    thanks_btn: 'Read other stories →',
    lang_note: 'Note: The form is in Japanese. If you\'re not comfortable writing in Japanese, feel free to write in your language — we\'ll do our best to understand.',
    image_hint_summary: '📷 Want to add a photo? (merchandise, pilgrimage spots, fan art, etc.)',
    image_hint_desc: 'Images are accepted via URL. Follow these steps:',
    image_hint_steps: ['Upload your image to X, Instagram, or Imgur (imgur.com)', 'Copy the direct URL of the image', 'Paste it into the "Image URL" field in the form'],
    image_hint_note: '※ Official manga panels and anime screenshots are not permitted. See guidelines for details.',
  },
  fr: {
    notice: 'Le formulaire de soumission est en japonais. Veuillez le remplir en japonais.',
    checklist_title: 'Avant de soumettre',
    checklist: [
      { icon: '📋', text: 'Avez-vous lu les', link_text: 'règles de soumission', link_path: '/guidelines' },
      { icon: '🔒', text: 'Ne pas inclure d\'informations personnelles (nom réel, adresse, etc.). Votre identifiant X est uniquement pour contact et ne sera pas publié.' },
    ],
    thanks_title: 'Soumission reçue !',
    thanks_desc: 'Merci. Après examen, votre histoire sera publiée dans quelques jours à une semaine.',
    thanks_x: 'Nous vous notifierons via notre compte X',
    thanks_btn: 'Lire les autres histoires →',
    lang_note: 'Note : Le formulaire est en japonais. Si vous n\'êtes pas à l\'aise pour écrire en japonais, n\'hésitez pas à écrire dans votre langue — nous ferons de notre mieux pour comprendre.',
    image_hint_summary: '📷 Vous souhaitez ajouter une photo ? (goodies, lieux de pèlerinage, fan art, etc.)',
    image_hint_desc: 'Les images sont acceptées via URL. Suivez ces étapes :',
    image_hint_steps: ['Téléchargez votre image sur X, Instagram ou Imgur (imgur.com)', 'Copiez l\'URL directe de l\'image', 'Collez-la dans le champ « URL de l\'image » du formulaire'],
    image_hint_note: '※ Les planches de manga officielles et les captures d\'anime ne sont pas autorisées. Consultez les règles pour plus de détails.',
  },
  ar: {
    notice: 'نموذج التقديم باللغة اليابانية. يرجى ملؤه باللغة اليابانية.',
    checklist_title: 'قبل الإرسال',
    checklist: [
      { icon: '📋', text: 'هل قرأت', link_text: 'إرشادات التقديم', link_path: '/guidelines' },
      { icon: '🔒', text: 'لا تُدرج معلومات شخصية (الاسم الحقيقي، العنوان، إلخ). معرّف X الخاص بك مخصص للتواصل فقط ولن يُنشر.' },
    ],
    thanks_title: 'تم استلام التقديم!',
    thanks_desc: 'شكراً لك. بعد المراجعة، ستُنشر قصتك في غضون أيام إلى أسبوع.',
    thanks_x: 'سنخبرك عبر حساب X الخاص بنا',
    thanks_btn: 'اقرأ القصص الأخرى →',
    lang_note: 'ملاحظة: النموذج باليابانية. إذا لم تكن مرتاحاً للكتابة باليابانية، فلا بأس بالكتابة بلغتك — سنبذل قصارى جهدنا للفهم.',
    image_hint_summary: '📷 هل تريد إضافة صورة؟ (بضائع، أماكن الحج، فن المعجبين، إلخ)',
    image_hint_desc: 'يتم قبول الصور عبر URL. اتبع الخطوات التالية:',
    image_hint_steps: ['ارفع صورتك على X أو Instagram أو Imgur (imgur.com)', 'انسخ رابط URL المباشر للصورة', 'الصقه في حقل "رابط الصورة" في النموذج'],
    image_hint_note: '※ لوحات المانغا الرسمية ولقطات الأنمي غير مسموح بها. راجع الإرشادات للتفاصيل.',
  },
  es: {
    notice: 'El formulario de envío está en japonés. Por favor, complétalo en japonés.',
    checklist_title: 'Antes de enviar',
    checklist: [
      { icon: '📋', text: '¿Has leído la', link_text: 'guía de envío', link_path: '/guidelines' },
      { icon: '🔒', text: 'No incluyas información personal (nombre real, dirección, etc.). Tu ID de X es solo para contacto y no se publicará.' },
    ],
    thanks_title: '¡Envío recibido!',
    thanks_desc: 'Gracias. Después de la revisión, tu historia se publicará en días o una semana.',
    thanks_x: 'Te notificaremos a través de nuestra cuenta de X',
    thanks_btn: 'Leer otras historias →',
    lang_note: 'Nota: El formulario está en japonés. Si no te sientes cómodo escribiendo en japonés, puedes escribir en tu idioma — haremos lo posible por entender.',
    image_hint_summary: '📷 ¿Quieres añadir una foto? (merchandising, lugares visitados, fan art, etc.)',
    image_hint_desc: 'Las imágenes se aceptan mediante URL. Sigue estos pasos:',
    image_hint_steps: ['Sube tu imagen a X, Instagram o Imgur (imgur.com)', 'Copia la URL directa de la imagen', 'Pégala en el campo "URL de imagen" del formulario'],
    image_hint_note: '※ Las páginas de manga oficiales y las capturas de pantalla de anime no están permitidas. Consulta las directrices para más detalles.',
  },
  pt: {
    notice: 'O formulário de envio está em japonês. Por favor, preencha-o em japonês.',
    checklist_title: 'Antes de enviar',
    checklist: [
      { icon: '📋', text: 'Você leu as', link_text: 'diretrizes de envio', link_path: '/guidelines' },
      { icon: '🔒', text: 'Não inclua informações pessoais (nome real, endereço, etc.). Seu ID do X é apenas para contato e não será publicado.' },
    ],
    thanks_title: 'Envio recebido!',
    thanks_desc: 'Obrigado. Após revisão, sua história será publicada em dias a uma semana.',
    thanks_x: 'Vamos notificá-lo através de nossa conta X',
    thanks_btn: 'Ler outras histórias →',
    lang_note: 'Nota: O formulário está em japonês. Se não se sentir confortável escrevendo em japonês, fique à vontade para escrever no seu idioma — faremos o possível para entender.',
    image_hint_summary: '📷 Quer adicionar uma foto? (merchandise, locais visitados, fan art, etc.)',
    image_hint_desc: 'As imagens são aceitas via URL. Siga estes passos:',
    image_hint_steps: ['Faça upload da sua imagem no X, Instagram ou Imgur (imgur.com)', 'Copie o URL direto da imagem', 'Cole no campo "URL da imagem" do formulário'],
    image_hint_note: '※ Painéis de manga oficiais e capturas de tela de anime não são permitidos. Consulte as diretrizes para mais detalhes.',
  },
  zh: {
    notice: '投稿表单为日语。请用日语填写。',
    checklist_title: '投稿前请确认',
    checklist: [
      { icon: '📋', text: '你是否已阅读', link_text: '投稿须知', link_path: '/guidelines' },
      { icon: '🔒', text: '请勿填写个人信息（真实姓名、地址等）。你的X ID仅用于联系，不会公开。' },
    ],
    thanks_title: '投稿已收到！',
    thanks_desc: '感谢你。审核后，你的故事将在几天到一周内发布。',
    thanks_x: '我们将通过我们的X账号通知你',
    thanks_btn: '阅读其他故事 →',
    lang_note: '注：表单为日语。如果你不擅长写日语，也可以用你的语言填写——我们会尽力理解。',
    image_hint_summary: '📷 想附上图片吗？（周边、圣地巡礼、同人画等）',
    image_hint_desc: '图片通过URL方式提交。请按以下步骤操作：',
    image_hint_steps: ['将图片上传至X、Instagram或Imgur（imgur.com）', '复制图片的直链URL', '将其粘贴到表单的"图片URL"栏中'],
    image_hint_note: '※ 官方漫画页面及动画截图不被允许。详情请参阅投稿须知。',
  },
  ko: {
    notice: '투고 폼은 일본어로 되어 있습니다. 일본어로 작성해 주세요.',
    checklist_title: '투고 전 확인',
    checklist: [
      { icon: '📋', text: '투고 가이드라인을', link_text: '읽으셨나요', link_path: '/guidelines' },
      { icon: '🔒', text: '개인정보（실명, 주소 등）는 기입하지 마세요. X ID는 연락용으로만 사용되며 공개되지 않습니다.' },
    ],
    thanks_title: '투고가 완료되었습니다!',
    thanks_desc: '감사합니다. 검토 후 며칠에서 일주일 이내에 게재됩니다.',
    thanks_x: '저희 X 계정을 통해 알려드리겠습니다',
    thanks_btn: '다른 이야기 읽기 →',
    lang_note: '참고: 폼은 일본어입니다. 일본어 작성이 어려우시면 자국어로 작성하셔도 됩니다——최대한 이해하도록 노력하겠습니다.',
    image_hint_summary: '📷 사진을 첨부하고 싶으신가요? (굿즈, 성지순례, 팬아트 등)',
    image_hint_desc: '이미지는 URL 방식으로 제출합니다. 아래 순서를 따라주세요:',
    image_hint_steps: ['X, Instagram 또는 Imgur(imgur.com)에 이미지 업로드', '이미지의 직접 링크 URL 복사', '폼의 "이미지 URL" 항목에 붙여넣기'],
    image_hint_note: '※ 공식 만화 컷 및 애니메이션 스크린샷은 허용되지 않습니다. 자세한 내용은 가이드라인을 참고해 주세요.',
  },
};

const c = notices[lang] ?? notices.en;
---

<BaseLayout
  title={t('submit.title')}
  description={t('submit.desc')}
  lang={lang}
  pagePath="/submit"
>
  <section class="page-header">
    <div class="page-header-inner">
      <h1 class="page-title">{t('submit.title')}</h1>
      <p class="page-desc">{t('submit.desc')}</p>
    </div>
  </section>

  <section class="submit-section">
    <div class="submit-inner">

      <div class="pre-submit-check">
        <h2>{c.checklist_title}</h2>
        {c.lang_note && <p class="submit-lang-note">{c.lang_note}</p>}
        <ul class="checklist">
          {c.checklist.map(item => (
            <li>
              <span class="check-icon">{item.icon}</span>
              {item.link_path ? (
                <span>{item.text} <a href={`${base}/${lang}${item.link_path}`}>{item.link_text}</a>?</span>
              ) : (
                <span>{item.text}</span>
              )}
            </li>
          ))}
        </ul>
      </div>

      <!-- 画像投稿ヒント -->
      <details class="image-hint">
        <summary>{c.image_hint_summary}</summary>
        <div class="image-hint-body">
          <p>{c.image_hint_desc}</p>
          <ol>
            {c.image_hint_steps.map(step => <li>{step}</li>)}
          </ol>
          <p class="image-hint-note">{c.image_hint_note}</p>
        </div>
      </details>

      <div id="form-embed-wrapper" class="form-embed-wrapper">
        <iframe
          id="google-form-iframe"
          src={FORM_URL}
          loading="lazy"
          title="Naruboru Fan Stories submission form"
        >Loading…</iframe>
      </div>

      <div id="submit-thanks" class="thanks-box" hidden>
        <div class="thanks-check">✓</div>
        <h2>{c.thanks_title}</h2>
        <p>{c.thanks_desc}</p>
        <p>{c.thanks_x} (<a href="https://x.com/naruboru_taiken" target="_blank" rel="noopener noreferrer">@naruboru_taiken</a>).</p>
        <a href={`${base}/${lang}/stories`} class="btn btn-primary" style="margin-top: 1.5rem; display: inline-block;">{c.thanks_btn}</a>
      </div>

      <p id="submit-guideline-link" class="submit-guideline-link">
        <a href={`${base}/${lang}/guidelines`}>{t('guidelines.title')}</a>
      </p>

    </div>
  </section>
</BaseLayout>

<script>
const iframe = document.getElementById('google-form-iframe') as HTMLIFrameElement;
let loadCount = 0;
iframe?.addEventListener('load', () => {
  loadCount++;
  if (loadCount < 2) return;
  document.getElementById('form-embed-wrapper')?.style.setProperty('display', 'none');
  document.getElementById('submit-guideline-link')?.style.setProperty('display', 'none');
  const thanks = document.getElementById('submit-thanks');
  if (thanks) {
    thanks.removeAttribute('hidden');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
});
</script>

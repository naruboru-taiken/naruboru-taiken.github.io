---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import StoryCard from '../../../components/StoryCard.astro';
import stories from '../../../data/stories.json';
import { SUPPORTED_LANGS, useTranslations, isSupportedLang, getStoryText, getAgeGroupLabel, getCharaName } from '../../../i18n/ui';
import type { SupportedLang } from '../../../i18n/ui';

export function getStaticPaths() {
  const list = stories as any[];
  return SUPPORTED_LANGS.flatMap(lang =>
    list.map((story, index) => ({
      params: { lang, id: story.id },
      props: {
        story,
        lang,
        prevStory: index > 0 ? { id: list[index-1].id, displayName: list[index-1].displayName } : null,
        nextStory: index < list.length - 1 ? { id: list[index+1].id, displayName: list[index+1].displayName } : null,
        allIds: list.map(s => s.id),
      },
    }))
  );
}

const { story, lang, prevStory, nextStory, allIds } = Astro.props as { story: any; lang: SupportedLang; prevStory: any; nextStory: any; allIds: string[] };
if (!isSupportedLang(lang)) return Astro.redirect(`/stories/${story.id}`);

const t = useTranslations(lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function truncate(text: string, max = 60) {
  return text.length > max ? text.slice(0, max) + '…' : text;
}

// Get translated or original text for each field
const mainStory = getStoryText(story, lang, 'mainStory');
const triggerScene = getStoryText(story, lang, 'triggerScene');
const realization = getStoryText(story, lang, 'realization');
const currentRelationship = getStoryText(story, lang, 'currentRelationship');
const favoriteScene = getStoryText(story, lang, 'favoriteScene');
const futureWish = getStoryText(story, lang, 'futureWish');
const message = getStoryText(story, lang, 'message');
const catchphrase = getStoryText(story, lang, 'catchphrase');

const displayCatchphrase =
  catchphrase ||
  (mainStory ? truncate(mainStory) : null) ||
  (triggerScene ? truncate(triggerScene) : null) ||
  '';

// Check if translation exists for main content
const hasTranslation = lang !== 'ja' && !!story.translations?.[lang];

function getRelatedStories(current: any, all: any[], count = 3) {
  return all
    .filter(s => s.id !== current.id)
    .map(s => {
      let score = 0;
      if (s.favoriteCharacter && current.favoriteCharacter && s.favoriteCharacter === current.favoriteCharacter) score += 3;
      if (s.firstSeries && s.firstSeries === current.firstSeries) score += 2;
      if (s.ageGroup && s.ageGroup === current.ageGroup) score += 1;
      if (s.firstMedia && s.firstMedia === current.firstMedia) score += 1;
      return { story: s, score };
    })
    .sort((a, b) =>
      b.score !== a.score
        ? b.score - a.score
        : new Date(b.story.publishedAt).getTime() - new Date(a.story.publishedAt).getTime()
    )
    .slice(0, count)
    .map(x => x.story);
}
const relatedStories = getRelatedStories(story, stories as any[]);

const favoriteCharacter = getCharaName(story.favoriteCharacter, lang);

const siteUrl = 'https://naruboru-taiken.github.io';
const storyUrl = `${siteUrl}/${lang}/stories/${story.id}`;
const ogpImageUrl = `${siteUrl}/ogp/${lang}/${story.id}.png`;
const shareText = `${story.displayName}'s NARUTO/BORUTO fan story${favoriteCharacter ? ` (fav: ${favoriteCharacter})` : ''}\nWhat was YOUR moment? Share yours too 🍃 #NaruboruFanStories`;
const xShareUrl = `https://x.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(storyUrl)}`;

const ageLabel = getAgeGroupLabel(story.ageGroup, lang);
---

<BaseLayout
  title={story.displayName + t('detail.title_suffix')}
  description={`「${displayCatchphrase}」— ${story.displayName}`}
  ogImage={ogpImageUrl}
  lang={lang}
  pagePath={`/stories/${story.id}`}
>
  <article class="story-detail">
    <div class="story-detail-inner">

      <!-- Breadcrumb -->
      <nav class="breadcrumb">
        <a href={`${base}/${lang}/`}>{t('detail.breadcrumb_home')}</a> &rsaquo;
        <a href={`${base}/${lang}/stories`}>{t('detail.breadcrumb_stories')}</a> &rsaquo;
        <span>{story.displayName}</span>
      </nav>

      <!-- Header -->
      <header class="story-header">
        <div class="story-tags">
          {story.firstSeries && <span class="tag tag-large">{story.firstSeries}</span>}
          {story.firstMedia && <span class="tag tag-large tag-media">{story.firstMedia}</span>}
        </div>
        <blockquote class="story-catchphrase">
          &ldquo;{displayCatchphrase}&rdquo;
        </blockquote>
        <div class="story-meta">
          <span class="story-name">{story.displayName}</span>
          {ageLabel && (
            <span class="story-meta-item">{t('detail.age_met')}{ageLabel}</span>
          )}
          {favoriteCharacter && (
            <span class="story-meta-item">{t('detail.fav_prefix')}{favoriteCharacter}</span>
          )}
          {story.country && (
            <span class="story-meta-item">{t('detail.country')}{getStoryText(story, lang, 'country')}</span>
          )}
          <span class="story-meta-item story-date">
            {new Date(story.publishedAt).toLocaleDateString(lang === 'ja' ? 'ja-JP' : lang === 'ar' ? 'ar' : 'en', {
              year: 'numeric', month: 'long', day: 'numeric'
            })}
          </span>
        </div>
        {!hasTranslation && lang !== 'ja' && (
          <p class="translation-notice">{t('detail.original_notice')}</p>
        )}
        {hasTranslation && (
          <p class="translation-notice translation-notice--translated">{t('detail.translated_notice')}</p>
        )}
      </header>

      <!-- Image -->
      {story.imageUrl && (
        <div class="story-image">
          <img src={story.imageUrl} alt={story.imageCaption ?? story.displayName} />
          {story.imageCaption && <p class="story-image-caption">{story.imageCaption}</p>}
        </div>
      )}

      <!-- Body -->
      <div class="story-body">
        {mainStory ? (
          <section class="story-section">
            <h2>{t('detail.main_story')}</h2>
            <p>{mainStory}</p>
          </section>
        ) : (
          <>
            {triggerScene && (
              <section class="story-section">
                <h2>{t('detail.trigger')}</h2>
                <p>{triggerScene}</p>
              </section>
            )}
            {realization && (
              <section class="story-section">
                <h2>{t('detail.realization')}</h2>
                <p>{realization}</p>
              </section>
            )}
            {currentRelationship && (
              <section class="story-section">
                <h2>{t('detail.current')}</h2>
                <p>{currentRelationship}</p>
              </section>
            )}
          </>
        )}

        {favoriteScene && (
          <section class="story-section">
            <h2>{t('detail.fav_scene')}</h2>
            <p>{favoriteScene}</p>
          </section>
        )}

        {futureWish && (
          <section class="story-section story-section--wish">
            <h2>{t('detail.future_wish')}</h2>
            <p>{futureWish}</p>
          </section>
        )}

        {message && (
          <section class="story-message">
            <p class="message-label">{t('detail.message_label')}</p>
            <blockquote class="message-quote">&ldquo;{message}&rdquo;</blockquote>
          </section>
        )}
      </div>

      <!-- Share buttons -->
      <div class="story-share">
        <p class="story-share-label">{t('detail.share_label')}</p>
        <a href={xShareUrl} target="_blank" rel="noopener noreferrer" class="btn btn-x-share">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.742l7.732-8.857L1.555 2.25H8.08l4.27 5.646L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
          </svg>
          {t('detail.share_x')}
        </a>
        <button type="button" id="ig-share-btn" class="btn btn-ig-share">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <circle cx="12" cy="12" r="5"/>
            <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" stroke="none"/>
          </svg>
          {t('detail.share_ig')}
        </button>
      </div>

      <!-- わかる！ & お気に入り -->
      <div class="story-engagement">
        <button type="button" id="like-btn" class="btn-like" aria-pressed="false">
          <span class="like-icon">🍥</span>
          <span class="like-label">{t('detail.like')}</span>
        </button>
        <button type="button" id="fav-btn" class="btn-favorite" aria-pressed="false">
          <span class="fav-icon">♡</span>
          <span class="fav-label">{t('detail.save')}</span>
        </button>
      </div>

      <!-- わかる！CTA バブル -->
      <div id="like-cta" class="like-cta" hidden aria-live="polite">
        <p class="like-cta-text">{t('detail.like_cta_text')}</p>
        <a href={`${base}/${lang}/submit`} class="like-cta-link">{t('detail.like_cta_btn')}</a>
        <button type="button" id="like-cta-close" class="like-cta-close" aria-label="閉じる">×</button>
      </div>

      <!-- Related stories -->
      {relatedStories.length > 0 && (
        <section class="related-stories">
          <h2 class="related-stories-title">{t('detail.related')}</h2>
          <div class="related-stories-grid">
            {relatedStories.map(s => <StoryCard story={s} lang={lang} />)}
          </div>
        </section>
      )}

      <!-- 前後ナビ & ランダム -->
      <nav class="story-nav">
        <div class="story-prev-next">
          {prevStory ? (
            <a href={`${base}/${lang}/stories/${prevStory.id}`} class="prev-next-link prev-link">
              <span class="prev-next-arrow">←</span>
              <span class="prev-next-name">{prevStory.displayName}</span>
            </a>
          ) : <span />}
          {nextStory ? (
            <a href={`${base}/${lang}/stories/${nextStory.id}`} class="prev-next-link next-link">
              <span class="prev-next-name">{nextStory.displayName}</span>
              <span class="prev-next-arrow">→</span>
            </a>
          ) : <span />}
        </div>
        <div class="story-nav-actions">
          <button type="button" id="random-btn" class="btn btn-outline">🎲 {t('stories.random')}</button>
          <a href={`${base}/${lang}/stories`} class="btn btn-outline">{t('detail.back')}</a>
          <a href={`${base}/${lang}/submit`} class="btn btn-primary">{t('detail.submit')}</a>
        </div>
      </nav>

    </div>
  </article>
</BaseLayout>

<script define:vars={{
  catchphrase: displayCatchphrase,
  displayName: story.displayName,
  storyUrl,
  firstSeries: story.firstSeries,
  firstMedia: story.firstMedia,
  mainStory: mainStory ?? null,
  triggerScene: triggerScene ?? null,
  realization: realization ?? null,
  currentRelationship: currentRelationship ?? null,
  favoriteScene: favoriteScene ?? null,
  futureWish: futureWish ?? null,
  message: message ?? null,
  generatingLabel: '',
  downloadToast: '',
  likeLabel: t('detail.like'),
  likedLabel: t('detail.liked'),
  saveLabel: t('detail.save'),
  savedLabel: t('detail.saved'),
  storyId: story.id,
  allIds,
  base,
  lang,
}}>
// ── 既読記録 ──
const readList = JSON.parse(localStorage.getItem('naruboru-read') || '[]');
if (!readList.includes(storyId)) {
  readList.push(storyId);
  localStorage.setItem('naruboru-read', JSON.stringify(readList));
}

// ── お気に入りボタン ──
const favBtn = document.getElementById('fav-btn');
const favList = () => JSON.parse(localStorage.getItem('naruboru-favorites') || '[]');
function updateFavBtn() {
  const isFav = favList().includes(storyId);
  favBtn.querySelector('.fav-icon').textContent = isFav ? '♥' : '♡';
  favBtn.querySelector('.fav-label').textContent = isFav ? savedLabel : saveLabel;
  favBtn.classList.toggle('favorited', isFav);
  favBtn.setAttribute('aria-pressed', String(isFav));
}
updateFavBtn();
favBtn?.addEventListener('click', () => {
  const list = favList();
  const idx = list.indexOf(storyId);
  if (idx === -1) list.push(storyId); else list.splice(idx, 1);
  localStorage.setItem('naruboru-favorites', JSON.stringify(list));
  updateFavBtn();
});

// ── わかる！ボタン ──
const likeBtn = document.getElementById('like-btn');
const likeList = () => JSON.parse(localStorage.getItem('naruboru-likes') || '[]');
function updateLikeBtn() {
  const isLiked = likeList().includes(storyId);
  likeBtn.querySelector('.like-label').textContent = isLiked ? likedLabel : likeLabel;
  likeBtn.classList.toggle('liked', isLiked);
  likeBtn.setAttribute('aria-pressed', String(isLiked));
}
updateLikeBtn();

// ── わかる！CTA バブル ──
let ctaTimer: ReturnType<typeof setTimeout> | null = null;

function showLikeCta() {
  const cta = document.getElementById('like-cta');
  if (!cta) return;
  cta.removeAttribute('hidden');
  requestAnimationFrame(() => {
    requestAnimationFrame(() => cta.classList.add('like-cta--visible'));
  });
  ctaTimer = setTimeout(hideLikeCta, 6000);
}

function hideLikeCta() {
  const cta = document.getElementById('like-cta');
  if (!cta) return;
  cta.classList.remove('like-cta--visible');
  setTimeout(() => cta.setAttribute('hidden', ''), 300);
  if (ctaTimer) { clearTimeout(ctaTimer); ctaTimer = null; }
}

document.getElementById('like-cta-close')?.addEventListener('click', hideLikeCta);

likeBtn?.addEventListener('click', () => {
  const list = likeList();
  const idx = list.indexOf(storyId);
  const wasLiked = idx !== -1;
  if (idx === -1) list.push(storyId); else list.splice(idx, 1);
  localStorage.setItem('naruboru-likes', JSON.stringify(list));
  updateLikeBtn();
  if (!wasLiked) showLikeCta();
});

// ── ランダムボタン ──
document.getElementById('random-btn')?.addEventListener('click', () => {
  const others = allIds.filter(id => id !== storyId);
  if (others.length === 0) return;
  const randomId = others[Math.floor(Math.random() * others.length)];
  window.location.href = `${base}/${lang}/stories/${randomId}`;
});

const btn = document.getElementById('ig-share-btn');
const originalHTML = btn.innerHTML;

btn.addEventListener('click', async () => {
  btn.disabled = true;
  btn.textContent = '…';

  try {
    await document.fonts.ready;

    const canvas = document.createElement('canvas');
    canvas.width = 1080;
    canvas.height = 1920;
    const ctx = canvas.getContext('2d');

    ctx.fillStyle = '#1a1a2e';
    ctx.fillRect(0, 0, 1080, 1920);

    const g1 = ctx.createRadialGradient(160, 360, 0, 160, 360, 560);
    g1.addColorStop(0, 'rgba(232,98,26,0.22)');
    g1.addColorStop(1, 'rgba(232,98,26,0)');
    ctx.fillStyle = g1;
    ctx.fillRect(0, 0, 1080, 1920);

    ctx.fillStyle = '#e8621a';
    ctx.fillRect(0, 0, 14, 1920);

    const logoX = 100, logoY = 104, logoR = 42;
    ctx.beginPath();
    ctx.arc(logoX, logoY, logoR, 0, Math.PI * 2);
    ctx.fillStyle = '#e8621a';
    ctx.fill();
    ctx.fillStyle = '#ffffff';
    ctx.font = 'bold 44px serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText('忍', logoX, logoY + 2);

    ctx.fillStyle = '#ffffff';
    ctx.font = 'bold 40px "Noto Sans JP", sans-serif';
    ctx.textAlign = 'left';
    ctx.textBaseline = 'middle';
    ctx.fillText('Naruboru Fan Stories', 162, logoY);

    ctx.beginPath();
    ctx.moveTo(60, 170);
    ctx.lineTo(1020, 170);
    ctx.strokeStyle = 'rgba(232,98,26,0.6)';
    ctx.lineWidth = 2;
    ctx.stroke();

    let curY = 200;
    ctx.fillStyle = '#e8621a';
    ctx.font = 'bold 54px "Noto Sans JP", sans-serif';
    ctx.textAlign = 'left';
    ctx.textBaseline = 'top';
    const catchN = drawWrapped(ctx, `「${catchphrase}」`, 60, curY, 960, 76);
    curY += catchN * 76 + 18;

    ctx.fillStyle = 'rgba(255,255,255,0.65)';
    ctx.font = '500 36px "Noto Sans JP", sans-serif';
    ctx.textAlign = 'left';
    ctx.textBaseline = 'middle';
    ctx.fillText(`— ${displayName}`, 60, curY + 22);

    const tagH = 50, tagR = 8;
    ctx.font = '500 28px "Noto Sans JP", sans-serif';
    if (firstSeries) {
      const tw1 = ctx.measureText(firstSeries).width + 32;
      const tw2 = firstMedia ? ctx.measureText(firstMedia).width + 32 : 0;
      drawPill(ctx, firstSeries, 1020 - tw2 - (tw2 ? 12 : 0) - tw1, curY - 2, tw1, tagH, tagR, '#e8621a');
      if (firstMedia) drawPill(ctx, firstMedia, 1020 - tw2, curY - 2, tw2, tagH, tagR, '#3d3d72');
    }
    curY += tagH + 32;

    ctx.beginPath();
    ctx.moveTo(60, curY);
    ctx.lineTo(1020, curY);
    ctx.strokeStyle = 'rgba(255,255,255,0.14)';
    ctx.lineWidth = 1;
    ctx.stroke();
    curY += 36;

    const BODY_MAX = 1780;
    const narrativeSections = mainStory
      ? [{ label: 'Story', text: mainStory }]
      : [
          triggerScene && { label: 'The scene that hooked me', text: triggerScene },
          realization && { label: 'When I realized I was a fan', text: realization },
          currentRelationship && { label: 'My relationship today', text: currentRelationship },
        ].filter(Boolean);
    const sections = [
      ...narrativeSections,
      favoriteScene && { label: 'Favorite scene', text: favoriteScene },
      futureWish && { label: 'Stories I\'d love to see', text: futureWish },
      message && { label: 'To fellow fans', text: message },
    ].filter(Boolean);

    for (let si = 0; si < sections.length; si++) {
      const section = sections[si];
      if (curY > BODY_MAX) break;
      ctx.fillStyle = '#e8621a';
      ctx.fillRect(60, curY, 6, 38);
      ctx.font = 'bold 30px "Noto Sans JP", sans-serif';
      ctx.textAlign = 'left';
      ctx.textBaseline = 'top';
      const headN = drawWrapped(ctx, section.label, 80, curY, 940, 42);
      curY += headN * 42 + 14;
      const remainingSections = sections.length - si;
      const availLines = Math.max(2, Math.floor((BODY_MAX - curY) / 50 / remainingSections));
      if (availLines <= 0) break;
      ctx.fillStyle = 'rgba(255,255,255,0.88)';
      ctx.font = '400 34px "Noto Sans JP", sans-serif';
      const bodyN = drawWrappedClamped(ctx, section.text, 60, curY, 960, 50, availLines);
      curY += bodyN * 50 + 44;
    }

    ctx.fillStyle = 'rgba(255,255,255,0.35)';
    ctx.font = '26px monospace';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'bottom';
    ctx.fillText('naruboru-taiken.github.io', 540, 1900);

    canvas.toBlob(async (blob) => {
      const file = new File([blob], 'naruboru-story.png', { type: 'image/png' });
      try {
        if (navigator.canShare && navigator.canShare({ files: [file] })) {
          await navigator.share({ files: [file] });
        } else {
          downloadBlob(blob);
          showToast('Image downloaded. Open Instagram and add it to your Stories.');
        }
      } catch (e) {
        if (e.name !== 'AbortError') {
          downloadBlob(blob);
          showToast('Image downloaded. Open Instagram and add it to your Stories.');
        }
      } finally {
        btn.disabled = false;
        btn.innerHTML = originalHTML;
      }
    }, 'image/png');

  } catch (e) {
    console.error(e);
    btn.disabled = false;
    btn.innerHTML = originalHTML;
  }
});

function drawWrapped(ctx, text, x, y, maxW, lineH) {
  const chars = [...text];
  let line = '';
  const lines = [];
  for (const ch of chars) {
    const test = line + ch;
    if (ctx.measureText(test).width > maxW && line !== '') { lines.push(line); line = ch; }
    else line = test;
  }
  if (line) lines.push(line);
  lines.forEach((l, i) => ctx.fillText(l, x, y + i * lineH));
  return lines.length;
}

function drawWrappedClamped(ctx, text, x, y, maxW, lineH, maxLines) {
  const allLines = [];
  for (const para of text.split('\n')) {
    if (para.trim() === '') continue;
    const chars = [...para];
    let line = '';
    for (const ch of chars) {
      const test = line + ch;
      if (ctx.measureText(test).width > maxW && line !== '') { allLines.push(line); line = ch; }
      else line = test;
    }
    if (line) allLines.push(line);
  }
  const truncated = allLines.length > maxLines;
  const lines = allLines.slice(0, maxLines);
  if (truncated && lines.length > 0) {
    let last = lines[lines.length - 1];
    while (last.length > 0 && ctx.measureText(last + '…').width > maxW) last = last.slice(0, -1);
    lines[lines.length - 1] = last + '…';
  }
  lines.forEach((l, i) => ctx.fillText(l, x, y + i * lineH));
  return lines.length;
}

function drawPill(ctx, text, x, y, w, h, r, bg) {
  ctx.beginPath();
  ctx.moveTo(x + r, y);
  ctx.lineTo(x + w - r, y);
  ctx.quadraticCurveTo(x + w, y, x + w, y + r);
  ctx.lineTo(x + w, y + h - r);
  ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
  ctx.lineTo(x + r, y + h);
  ctx.quadraticCurveTo(x, y + h, x, y + h - r);
  ctx.lineTo(x, y + r);
  ctx.quadraticCurveTo(x, y, x + r, y);
  ctx.closePath();
  ctx.fillStyle = bg;
  ctx.fill();
  ctx.fillStyle = '#ffffff';
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillText(text, x + w / 2, y + h / 2);
}

function downloadBlob(blob) {
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = 'naruboru-story.png';
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  setTimeout(() => URL.revokeObjectURL(url), 1000);
}

function showToast(message) {
  const toast = document.createElement('div');
  toast.className = 'share-toast';
  toast.textContent = message;
  document.body.appendChild(toast);
  requestAnimationFrame(() => requestAnimationFrame(() => toast.classList.add('share-toast--visible')));
  setTimeout(() => {
    toast.classList.remove('share-toast--visible');
    setTimeout(() => toast.remove(), 400);
  }, 5000);
}
</script>

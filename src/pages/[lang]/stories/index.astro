---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import StoryCard from '../../../components/StoryCard.astro';
import stories from '../../../data/stories.json';
import { SUPPORTED_LANGS, useTranslations, isSupportedLang } from '../../../i18n/ui';
import type { SupportedLang } from '../../../i18n/ui';

export function getStaticPaths() {
  return SUPPORTED_LANGS.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: SupportedLang };
if (!isSupportedLang(lang)) return Astro.redirect('/stories');

const t = useTranslations(lang);

const sorted = [...stories].sort((a, b) => {
  const d = new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime();
  return d !== 0 ? d : b.id.localeCompare(a.id);
});

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title={t('stories.title')}
  description={t('stories.desc', { count: stories.length })}
  lang={lang}
  pagePath="/stories"
>
  <section class="page-header">
    <div class="page-header-inner">
      <h1 class="page-title">{t('stories.title')}</h1>
      <p class="page-desc">
        <strong id="story-count">{stories.length}</strong> {lang === 'ar' ? 'قصة' : lang === 'ja' ? '件' : ''}
        {lang !== 'ar' && lang !== 'ja' && t('stories.desc', { count: stories.length }).replace(/\d+/, '').trim()}
      </p>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">

      <!-- Filter + Sort + Random -->
      <div class="filter-toolbar">
        <div class="filter-bar" role="group" aria-label="Filter by series">
          <button class="filter-btn active" data-filter="all">{t('stories.filter_all')}</button>
          <button class="filter-btn" data-filter="NARUTO">NARUTO</button>
          <button class="filter-btn" data-filter="BORUTO">BORUTO</button>
        </div>
        <div class="filter-toolbar-right">
          <select id="sort-select" class="sort-select" aria-label={t('stories.sort_label')}>
            <option value="new">{t('stories.sort_new')}</option>
            <option value="age-asc">{t('stories.sort_age_asc')}</option>
            <option value="age-desc">{t('stories.sort_age_desc')}</option>
          </select>
          <button id="random-btn" class="btn-random" type="button">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="3"/>
              <circle cx="8" cy="8" r="1.5" fill="currentColor" stroke="none"/>
              <circle cx="16" cy="8" r="1.5" fill="currentColor" stroke="none"/>
              <circle cx="12" cy="12" r="1.5" fill="currentColor" stroke="none"/>
              <circle cx="8" cy="16" r="1.5" fill="currentColor" stroke="none"/>
              <circle cx="16" cy="16" r="1.5" fill="currentColor" stroke="none"/>
            </svg>
            {t('stories.random')}
          </button>
        </div>
      </div>

      <!-- Chara filter chip -->
      <div id="chara-filter-chip" class="chara-filter-chip" hidden>
        <span>{t('stories.fav_prefix')}<strong id="chara-filter-name"></strong></span>
        <button id="chara-filter-clear" type="button" aria-label={t('stories.fav_clear')}>×</button>
      </div>

      <div class="card-grid" id="story-grid">
        {sorted.map((story) => (
          <StoryCard story={story} lang={lang} />
        ))}
      </div>

      <p id="no-results" class="filter-no-results" hidden>
        {t('stories.no_results')}
      </p>

      <div class="submit-nudge">
        <p>{t('stories.nudge')}</p>
        <a href={`${base}/${lang}/submit`} class="btn btn-primary">{t('stories.nudge_btn')}</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
const cards = Array.from(document.querySelectorAll<HTMLElement>('.story-card'));
const countEl = document.getElementById('story-count');
const noResults = document.getElementById('no-results');
const grid = document.getElementById('story-grid');

let currentSeries = 'all';
let currentChara = '';

const charaParam = new URLSearchParams(window.location.search).get('chara') ?? '';
if (charaParam) {
  currentChara = charaParam;
  const chip = document.getElementById('chara-filter-chip');
  const nameEl = document.getElementById('chara-filter-name');
  chip?.removeAttribute('hidden');
  if (nameEl) nameEl.textContent = charaParam;
}

function applyFilters() {
  let visible = 0;
  cards.forEach(card => {
    const seriesOk = currentSeries === 'all' || card.dataset.series === currentSeries;
    const charaOk = !currentChara || card.dataset.chara === currentChara;
    const show = seriesOk && charaOk;
    card.style.display = show ? '' : 'none';
    if (show) visible++;
  });
  if (countEl) countEl.textContent = String(visible);
  if (noResults) noResults.hidden = visible > 0;
}
applyFilters();

document.querySelectorAll<HTMLButtonElement>('.filter-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    currentSeries = btn.dataset.filter ?? 'all';
    applyFilters();
  });
});

document.getElementById('chara-filter-clear')?.addEventListener('click', () => {
  currentChara = '';
  document.getElementById('chara-filter-chip')?.setAttribute('hidden', '');
  applyFilters();
  const url = new URL(window.location.href);
  url.searchParams.delete('chara');
  history.replaceState({}, '', url);
});

const ageOrder: Record<string, number> = {
  '〜10歳': 0, '10代': 1, '20代': 2, '30代': 3, '40代以上': 4, '覚えていない': 5,
};
document.getElementById('sort-select')?.addEventListener('change', (e) => {
  const key = (e.target as HTMLSelectElement).value;
  if (!grid) return;
  const all = Array.from(grid.querySelectorAll<HTMLElement>('.story-card'));
  all.sort((a, b) => {
    if (key === 'age-asc') return (ageOrder[a.dataset.ageGroup ?? ''] ?? 99) - (ageOrder[b.dataset.ageGroup ?? ''] ?? 99);
    if (key === 'age-desc') return (ageOrder[b.dataset.ageGroup ?? ''] ?? -1) - (ageOrder[a.dataset.ageGroup ?? ''] ?? -1);
    const d = new Date(b.dataset.publishedAt ?? '').getTime() - new Date(a.dataset.publishedAt ?? '').getTime();
    return d !== 0 ? d : (b.dataset.storyId ?? '').localeCompare(a.dataset.storyId ?? '');
  });
  all.forEach(card => grid.appendChild(card));
});

document.getElementById('random-btn')?.addEventListener('click', () => {
  const visible = cards.filter(c => c.style.display !== 'none');
  if (!visible.length) return;
  const card = visible[Math.floor(Math.random() * visible.length)];
  const link = card.querySelector<HTMLAnchorElement>('.card-link');
  if (link) window.location.href = link.href;
});
</script>

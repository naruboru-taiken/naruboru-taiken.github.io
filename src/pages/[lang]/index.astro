---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StoryCard from '../../components/StoryCard.astro';
import stories from '../../data/stories.json';
import { SUPPORTED_LANGS, useTranslations, isSupportedLang } from '../../i18n/ui';
import type { SupportedLang } from '../../i18n/ui';

export function getStaticPaths() {
  return SUPPORTED_LANGS.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: SupportedLang };
if (!isSupportedLang(lang)) return Astro.redirect('/');

const t = useTranslations(lang);

const latestStories = [...stories]
  .sort((a, b) => {
    const d = new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime();
    return d !== 0 ? d : b.id.localeCompare(a.id);
  })
  .slice(0, 9);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const countries = [...new Set(stories.map((s: any) => s.country).filter(Boolean))];
const countryCount = countries.length;
const realCount = (stories as any[]).filter(s => !s.isSeedContent).length;
const GOAL = 100;
const pct100 = Math.min(100, Math.round((realCount / GOAL) * 100));
const nextMilestone100 = [20, 30, 50, 75, 100].find(m => m > realCount) ?? 100;
---

<BaseLayout
  title={t('footer.home')}
  description={t('site.description')}
  lang={lang}
  pagePath="/"
>

  <!-- SVG ノイズフィルター定義 -->
  <svg aria-hidden="true" focusable="false" style="position:absolute;width:0;height:0;overflow:hidden">
    <defs>
      <filter id="grain-filter" x="0%" y="0%" width="100%" height="100%" color-interpolation-filters="sRGB">
        <feTurbulence type="fractalNoise" baseFrequency="0.72" numOctaves="4" stitchTiles="stitch" result="noise"/>
        <feColorMatrix type="saturate" values="0" in="noise" result="grayNoise"/>
        <feComposite in="grayNoise" in2="SourceGraphic" operator="in"/>
      </filter>
    </defs>
  </svg>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-pattern"></div>
      <div class="hero-emitter"></div>
      <div class="hero-emitter-core"></div>
      <div class="hero-noise"></div>
    </div>
    <div class="hero-inner">
      <p class="hero-eyebrow">{t('home.eyebrow')}</p>
      <h1 class="hero-title">{t('home.title')}</h1>
      <p class="hero-desc">{t('home.desc')}</p>
      <div class="hero-actions">
        <a href={`${base}/${lang}/stories`} class="btn btn-primary">{t('home.read_all')}</a>
        <a href={`${base}/${lang}/submit`} class="btn btn-outline">{t('home.submit')}</a>
      </div>

      <div class="hero-meta">
        <div class="hero-meta-stats" aria-label="site stats">
          <span class="hero-meta-num">{realCount}</span>
          <span class="hero-meta-unit">{t('home.meta_stories_unit')}</span>
          <span class="hero-meta-sep" aria-hidden="true">·</span>
          <span class="hero-meta-num">{countryCount}</span>
          <span class="hero-meta-unit">{t('home.meta_countries_unit')}</span>
        </div>
        <span class="hero-meta-divider" aria-hidden="true"></span>
        {realCount >= 20 ? (
          <a href={`${base}/${lang}/project100`} class="hero-meta-p100" aria-label={`PROJECT 100: ${realCount}/${GOAL}`}>
            <span class="hero-meta-p100-label">PROJECT 100</span>
            <span class="hero-meta-p100-bar" role="progressbar" aria-valuenow={realCount} aria-valuemin={0} aria-valuemax={GOAL}>
              <span class="hero-meta-p100-fill" style={`width: ${pct100}%`}></span>
            </span>
            <span class="hero-meta-p100-count">{realCount}<span class="hero-meta-p100-goal">/{GOAL}{t('home.p100_goal_unit')}</span></span>
            <span class="hero-meta-p100-arrow" aria-hidden="true">→</span>
          </a>
        ) : (
          <span class="hero-meta-p100" style="cursor: default; pointer-events: none;">
            <span class="hero-meta-p100-label">PROJECT 100</span>
            <span class="hero-meta-p100-bar" role="progressbar" aria-valuenow={realCount} aria-valuemin={0} aria-valuemax={GOAL}>
              <span class="hero-meta-p100-fill" style={`width: ${pct100}%`}></span>
            </span>
            <span class="hero-meta-p100-count">{realCount}<span class="hero-meta-p100-goal">/{GOAL}{t('home.p100_goal_unit')}</span></span>
          </span>
        )}
      </div>
    </div>
  </section>

  <!-- Latest stories -->
  <section class="section">
    <div class="section-inner">
      <div class="section-header">
        <h2 class="section-title">{t('home.latest')}</h2>
        <a href={`${base}/${lang}/stories`} class="section-link">{t('home.view_all')}</a>
      </div>
      <div class="card-grid">
        {latestStories.map((story) => (
          <StoryCard story={story} lang={lang} />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="cta-inner">
      <h2 class="cta-title">{t('home.cta_title')}</h2>
      <p class="cta-desc">{t('home.cta_desc')}</p>
      <a href={`${base}/${lang}/submit`} class="btn btn-primary btn-large">{t('home.cta_btn')}</a>
      <p class="cta-note">
        <a href={`${base}/${lang}/guidelines`}>{t('home.cta_guidelines')}</a>
        {lang !== 'ja' && <span class="cta-note-sub"> — {t('home.cta_note')}</span>}
      </p>
    </div>
  </section>

</BaseLayout>

    chara_title: 'Favorite Characters — Top 10',
    country_title: 'Countries & Regions',
    wish_title: 'Stories Fans Want to See',
    wish_note: `From ${wishCount} stories (selected excerpts)`,
    read_all: 'Read All Stories',
    unit: '',
    ageLabels: { '〜10歳': 'Under 10', '10代': 'Teens', '20代': '20s', '30代': '30s', '40代以上': '40s+', '覚えていない': 'Unknown' },
    mediaLabels: { 'TVアニメ': 'TV Anime', '漫画（連載・単行本）': 'Manga', '映画': 'Film', '二次創作・SNS・人の話': 'Fan content / SNS / Word of mouth', 'その他': 'Other' },
  },

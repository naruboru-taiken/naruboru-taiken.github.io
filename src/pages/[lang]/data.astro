---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SUPPORTED_LANGS, isSupportedLang, getCharaName } from '../../i18n/ui';
import type { SupportedLang } from '../../i18n/ui';
import storiesRaw from '../../data/stories.json';

export function getStaticPaths() {
  return SUPPORTED_LANGS.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: SupportedLang };
if (!isSupportedLang(lang)) return Astro.redirect('/data');

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

type Story = {
  id: string;
  displayName: string;
  ageGroup?: string | null;
  favoriteCharacter?: string | null;
  firstSeries?: string | null;
  firstMedia?: string | null;
  futureWish?: string | null;
  country?: string | null;
  isSeedContent?: boolean;
  translations?: Record<string, Record<string, string | null>>;
};
const stories = storiesRaw as Story[];
const total = stories.length;

// Label translations（wishカウントはシードコンテンツを除外）
const wishCount = stories.filter(s => !s.isSeedContent && (s.futureWish || s.translations?.ja?.futureWish)).length;

const content = {

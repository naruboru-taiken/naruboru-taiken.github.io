    chara_title: 'الشخصيات المفضلة — أفضل 10',
    country_title: 'الدول والمناطق',
    wish_title: 'قصص يتمنى المحبون رؤيتها',
    wish_note: `من ${wishCount} قصة (مقتطفات مختارة)`,
    read_all: 'قراءة جميع القصص',

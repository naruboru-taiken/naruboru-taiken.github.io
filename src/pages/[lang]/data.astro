    media_title: "Premier support",
    series_title: "Première série",
    chara_title: "Personnages préférés — Top 10",
    country_title: "Pays et régions",
    wish_title: "Ce que les fans aimeraient voir",
    wish_note: `Parmi ${wishCount} témoignages (extraits)`,
    read_all: 'Lire tous les témoignages',
    unit: '',
    ageLabels: { '〜10歳': 'Moins de 10 ans', '10代': 'Ados', '20代': '20 ans', '30代': '30 ans', '40代以上': '40 ans +', '覚えていない': 'Inconnu' },
    mediaLabels: { 'TVアニメ': 'Anime TV', '漫画（連載・単行本）': 'Manga', '映画': 'Film', '二次創作・SNS・人の話': 'Fan art / Réseaux sociaux / Bouche-à-oreille', 'その他': 'Autre' },
  },
  ar: {
    title: 'إحصائيات',
    description: `بيانات مستخلصة من ${total} قصة من قصص المحبين.`,
    subtitle: `رؤى من ${total} قصة`,
    age_title: 'العمر عند اكتشاف السلسلة',
    age_note: 'العمر عند اللقاء الأول مع NARUTO أو BORUTO',
    media_title: 'الوسيلة الأولى',

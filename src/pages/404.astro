---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="ページが見つかりません"
  description="お探しのページは見つかりませんでした。"
  lang="ja"
  pagePath="/404"
>
  <div class="not-found">
    <div class="not-found-inner">
      <p class="not-found-code">404</p>
      <h1 class="not-found-title">ページが見つかりませんでした</h1>
      <p class="not-found-body">
        お探しのページは存在しないか、移動・削除された可能性があります。
      </p>
      <div class="not-found-actions">
        <a href={`${base}/`} class="btn btn-primary">トップへ戻る</a>
        <a href={`${base}/stories`} class="btn btn-secondary">体験談を読む</a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .not-found {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 60vh;
    padding: 3rem 1rem;
    text-align: center;
  }
  .not-found-inner {
    max-width: 480px;
  }
  .not-found-code {
    font-size: 7rem;
    font-weight: 900;
    color: var(--color-primary);
    line-height: 1;
    margin: 0 0 0.5rem;
    opacity: 0.8;
  }
  .not-found-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-accent);
    margin: 0 0 1rem;
  }
  .not-found-body {
    color: #666;
    margin: 0 0 2rem;
    line-height: 1.8;
  }
  .not-found-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    border-radius: var(--radius);
    font-weight: 700;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .btn:hover { opacity: 0.85; }
  .btn-primary {
    background: var(--color-primary);
    color: #fff;
  }
  .btn-secondary {
    background: var(--color-accent);
    color: #fff;
  }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';

const FORM_URL = 'https://docs.google.com/forms/d/e/1FAIpQLSc5haprqYIM3MX0FdsuPVZinmbA4xPljPETYs1ewAfL9EW59Q/viewform?embedded=true';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="体験談を投稿する" description="NARUTO・BORUTOファン体験談サイトへの投稿ページです。">
  <section class="page-header">
    <div class="page-header-inner">
      <h1 class="page-title">体験談を投稿する</h1>
      <p class="page-desc">
        あなたとNARUTO・BORUTOの出会いを教えてください。<br />
        投稿内容は運営が確認後に掲載します。
      </p>
    </div>
  </section>

  <section class="submit-section">
    <div class="submit-inner">

      <!-- 投稿前チェックリスト -->
      <div class="pre-submit-check">
        <h2>投稿前の確認</h2>
        <ul class="checklist">
          <li>
            <span class="check-icon">📋</span>
            <a href={`${base}/guidelines`}>投稿ガイドライン</a>を読みましたか？
          </li>
          <li>
            <span class="check-icon">🔒</span>
            本名・住所などの個人情報は記入しないでください。
            X IDは連絡専用で、サイトには公開されません。
          </li>
        </ul>
      </div>

      <!-- フォーム埋め込みエリア -->
      <!-- フォームURLを変更する場合: src/pages/submit.astro 冒頭の FORM_URL を更新してください -->
      <div id="form-embed-wrapper" class="form-embed-wrapper">
        <iframe
          id="google-form-iframe"
          src={FORM_URL}
          loading="lazy"
          title="ナルボル体験談投稿フォーム"
        >読み込んでいます…</iframe>
      </div>

      <!-- 投稿完了メッセージ（iframe再loadで表示） -->
      <div id="submit-thanks" class="thanks-box" hidden>
        <div class="thanks-check">✓</div>
        <h2>投稿を受け付けました！</h2>
        <p>ありがとうございます。内容を確認後、数日〜1週間程度で掲載します。</p>
        <p>掲載後はXアカウント（<a href="https://x.com/naruto_2024" target="_blank" rel="noopener noreferrer">@naruto_2024</a>）でお知らせします。</p>
        <a href={`${base}/stories`} class="btn btn-primary" style="margin-top: 1.5rem; display: inline-block;">みんなの体験談を読む →</a>
      </div>

      <!-- ガイドライン再掲リンク -->
      <p id="submit-guideline-link" class="submit-guideline-link">
        投稿に迷ったら <a href={`${base}/guidelines`}>投稿ガイドライン</a> をご確認ください。
      </p>

    </div>
  </section>
</BaseLayout>

<script>
// Googleフォームは送信後にiframe内のページが切り替わり、loadイベントが再発火する
// 初回load（フォーム表示）はスキップし、2回目以降（送信完了）で完了画面を表示する
const iframe = document.getElementById('google-form-iframe') as HTMLIFrameElement;
let loadCount = 0;

iframe?.addEventListener('load', () => {
  loadCount++;
  if (loadCount < 2) return; // 初回loadはスキップ

  document.getElementById('form-embed-wrapper')?.style.setProperty('display', 'none');
  document.getElementById('submit-guideline-link')?.style.setProperty('display', 'none');
  const thanks = document.getElementById('submit-thanks');
  if (thanks) {
    thanks.removeAttribute('hidden');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
});
</script>

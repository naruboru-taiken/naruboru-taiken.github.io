---
import BaseLayout from '../layouts/BaseLayout.astro';

const TALLY_EMBED_URL = 'https://tally.so/embed/dWl9Lz?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="体験談を投稿する" description="ナルボル体験談サイトへの投稿ページです。">
  <section class="page-header">
    <div class="page-header-inner">
      <h1 class="page-title">体験談を投稿する</h1>
      <p class="page-desc">
        あなたのナルボルとの出会いを教えてください。<br />
        投稿内容は運営が確認後に掲載します。
      </p>
    </div>
  </section>

  <section class="submit-section">
    <div class="submit-inner">

      <!-- 投稿前チェックリスト -->
      <div class="pre-submit-check">
        <h2>投稿前の確認</h2>
        <ul class="checklist">
          <li>
            <span class="check-icon">📋</span>
            <a href={`${base}/guidelines`}>投稿ガイドライン</a>を読みましたか？
          </li>
          <li>
            <span class="check-icon">🚫</span>
            <span><strong>公式漫画のコマ・アニメのキャプチャ・他者の二次創作イラストは添付しないでください。</strong>発見した場合は画像のみ非公開になります。</span>
          </li>
          <li>
            <span class="check-icon">🔒</span>
            本名・住所などの個人情報は記入しないでください。
            X IDは連絡専用で、サイトには公開されません。
          </li>
        </ul>
      </div>

      <!-- フォーム埋め込みエリア -->
      <!-- フォームURLを変更する場合: src/pages/submit.astro 冒頭の TALLY_EMBED_URL を更新してください -->
      <div class="form-embed-wrapper">
        <iframe
          data-tally-src={TALLY_EMBED_URL}
          loading="lazy"
          width="100%"
          height="500"
          frameborder="0"
          marginheight="0"
          marginwidth="0"
          title="ナルボル体験談投稿フォーム"
          class="tally-iframe"
        ></iframe>
        <script src="https://tally.so/widgets/embed.js" is:inline></script>
      </div>

      <!-- ガイドライン再掲リンク -->
      <p class="submit-guideline-link">
        投稿に迷ったら <a href={`${base}/guidelines`}>投稿ガイドライン</a> をご確認ください。
      </p>

    </div>
  </section>
</BaseLayout>

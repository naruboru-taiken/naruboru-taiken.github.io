<style>
/* ================================================================
   モックアップ v6 専用スタイル (mk-* prefix)
   global.css の CSS変数のみ参照。Satori対象外。
   ================================================================ */

/* ===== Keyframes ===== */

@keyframes mk-emitter-breathe {
  0%   { opacity: 0.82; transform: scaleY(1)    scaleX(1); }
  25%  { opacity: 1;    transform: scaleY(1.18) scaleX(1.06); }
  55%  { opacity: 0.88; transform: scaleY(0.96) scaleX(1.02); }
  80%  { opacity: 0.95; transform: scaleY(1.10) scaleX(0.98); }
  100% { opacity: 0.82; transform: scaleY(1)    scaleX(1); }
}
@keyframes mk-emitter-core-pulse {
  0%, 100% { opacity: 0.70; transform: scaleY(1)    scaleX(1); }
  35%       { opacity: 1;    transform: scaleY(1.24) scaleX(1.10); }
  65%       { opacity: 0.80; transform: scaleY(0.92) scaleX(0.96); }
}
@keyframes mk-ambient-drift {
  0%, 100% { transform: translate(0, 0); }
  50%       { transform: translate(16px, -12px); }
}
@keyframes mk-cursor-blink {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0; }
}
@keyframes mk-quote-in {
  from { opacity: 0; transform: translateY(6px) scale(0.96); }
  to   { opacity: 0.085; transform: translateY(0) scale(1); }
}
/* スクロール矢印のバウンス */
@keyframes mk-bounce {
  0%, 100% { transform: translateY(0); }
  50%       { transform: translateY(6px); }
}
/* ヒーロースニペットのフェードイン（タイピング完了後） */
@keyframes mk-snippet-in {
  from { opacity: 0; transform: translateX(16px); }
  to   { opacity: 1; transform: translateX(0); }
}

/* ===== SVG定義（非表示） ===== */
.mk-svg-defs {
  position: absolute;
  width: 0;
  height: 0;
  overflow: hidden;
  pointer-events: none;
}

/* ===== Notice ===== */
.mk-notice {
  background: #0d0d1e;
  color: rgba(255,255,255,0.45);
  font-size: 0.76rem;
  text-align: center;
  padding: 0.5rem 1rem;
  letter-spacing: 0.04em;
  font-family: var(--font-body);
}

/* ===== Header ===== */
.mk-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(26,26,46,0.96);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid rgba(232,98,26,0.18);
  box-shadow: 0 1px 24px rgba(0,0,0,0.22);
}
.mk-header-inner {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 2rem;
  height: 64px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
}
.mk-logo {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  color: #fff;
  text-decoration: none;
  font-weight: 700;
  font-size: 1.05rem;
  font-family: var(--font-body);
}
.mk-logo:hover { color: var(--color-primary); text-decoration: none; }
.mk-logo-mark {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 34px;
  height: 34px;
  background: linear-gradient(135deg, var(--color-primary) 0%, #c04e10 100%);
  color: white;
  border-radius: 50%;
  font-size: 0.95rem;
  font-weight: 700;
  box-shadow: 0 0 12px rgba(232,98,26,0.4);
  flex-shrink: 0;
  font-family: var(--font-body);
}
.mk-nav {
  display: flex;
  align-items: center;
  gap: 1.75rem;
}
.mk-nav-link {
  font-size: 0.88rem;
  color: rgba(255,255,255,0.72);
  font-weight: 500;
  text-decoration: none;
  font-family: var(--font-body);
  transition: color 0.18s;
}
.mk-nav-link:hover { color: var(--color-primary); text-decoration: none; }

/* ===== Buttons ===== */
.mk-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0.7rem 1.6rem;
  border-radius: 100px;
  font-size: 0.9rem;
  font-weight: 700;
  text-decoration: none;
  transition: background 0.18s, border-color 0.18s, color 0.18s,
              box-shadow 0.18s, transform 0.18s;
  border: 2px solid transparent;
  cursor: pointer;
  font-family: var(--font-body);
  white-space: nowrap;
}
.mk-btn-primary {
  background: linear-gradient(135deg, var(--color-primary) 0%, #d4561a 100%);
  color: #fff;
  border-color: var(--color-primary);
  box-shadow: 0 4px 14px rgba(232,98,26,0.28);
}
.mk-btn-primary:hover {
  background: linear-gradient(135deg, var(--color-primary-dark) 0%, #b34412 100%);
  border-color: var(--color-primary-dark);
  text-decoration: none;
  color: #fff;
  box-shadow: 0 6px 22px rgba(232,98,26,0.48);
  transform: translateY(-1px);
}
.mk-btn-outline-white {
  background: transparent;
  color: rgba(255,255,255,0.9);
  border-color: rgba(255,255,255,0.42);
}
.mk-btn-outline-white:hover {
  background: rgba(255,255,255,0.1);
  border-color: rgba(255,255,255,0.7);
  color: #fff;
  text-decoration: none;
}
.mk-btn-sm  { padding: 0.45rem 1.1rem; font-size: 0.82rem; }
.mk-btn-lg  { padding: 0.95rem 2.4rem; font-size: 1rem; }

/* ===== Hero ===== */
.mk-hero {
  position: relative;
  background: var(--color-accent);
  color: white;
  overflow: hidden;
  padding: 5rem 0 5.5rem;
}

/* --- 背景レイヤー群 --- */
.mk-hero-bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
}
/* 環境光 */
.mk-hero-ambient {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 45% 40% at 12% 22%, rgba(232,98,26,0.10) 0%, transparent 55%),
    radial-gradient(ellipse 30% 35% at 88% 18%, rgba(232,98,26,0.06) 0%, transparent 50%);
  animation: mk-ambient-drift 14s ease-in-out infinite;
}
/* チャクラ炎ベース */
.mk-hero-chakra {
  position: absolute;
  left: -5%;
  right: -5%;
  bottom: 0;
  height: 65%;
  background: radial-gradient(ellipse 110% 85% at 50% 120%,
    rgba(140,50,8,0.45) 0%,
    rgba(100,30,3,0.18) 40%,
    transparent 68%
  );
}
/* 発光体（blur + screen） */
.mk-hero-emitter {
  position: absolute;
  bottom: 0;
  left: -20%;
  right: -20%;
  height: 70%;
  transform-origin: bottom center;
  background: radial-gradient(ellipse 85% 80% at 50% 110%,
    rgba(232,98,26,1.0)  0%,
    rgba(220,75,10,0.85) 18%,
    rgba(190,50, 5,0.50) 38%,
    rgba(140,30, 2,0.15) 60%,
    transparent 78%
  );
  filter: blur(72px);
  mix-blend-mode: screen;
  animation: mk-emitter-breathe 6s ease-in-out infinite;
  pointer-events: none;
}
/* 発光コア */
.mk-hero-emitter-core {
  position: absolute;
  bottom: 0;
  left: 20%;
  right: 20%;
  height: 40%;
  transform-origin: bottom center;
  background: radial-gradient(ellipse 70% 85% at 50% 115%,
    rgba(255,140,50,1.0)  0%,
    rgba(245,100,20,0.90) 20%,
    rgba(220, 70, 5,0.45) 50%,
    transparent 75%
  );
  filter: blur(48px);
  mix-blend-mode: screen;
  animation: mk-emitter-core-pulse 4s ease-in-out infinite;
  pointer-events: none;
}
/* ノイズテクスチャ */
.mk-hero-noise {
  position: absolute;
  inset: 0;
  background: #aaa;
  filter: url(#mk-grain-filter);
  opacity: 0.042;
  mix-blend-mode: overlay;
}
/* 忍の透かし — 2カラム化に伴い中央寄りに移動・opacity微調整 */
.mk-hero-kanji {
  position: absolute;
  right: 0%;
  top: 50%;
  transform: translateY(-50%);
  font-size: clamp(12rem, 22vw, 22rem);
  font-weight: 700;
  font-family: var(--font-body);
  color: rgba(255,255,255,0.032);
  line-height: 1;
  user-select: none;
  pointer-events: none;
}

/* --- ヒーロー 2カラムレイアウト --- */
.mk-hero-inner {
  position: relative;
  z-index: 1;
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 2rem;
  display: flex;
  align-items: center;
  gap: 3.5rem;
}
.mk-hero-copy {
  flex: 0 0 54%;
  min-width: 0;
}

/* eyebrow */
.mk-eyebrow {
  display: inline-flex;

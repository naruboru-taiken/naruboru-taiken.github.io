<script>
// ================================================================
// タイピングエフェクト（ヒーロータイトル）
// タイピング完了時刻をスニペットのアニメーション遅延と揃えている
// ================================================================
(function () {
  const target = document.querySelector<HTMLElement>('.mk-typing-target');
  const titleEl = target?.parentElement;
  if (!target || !titleEl) return;

  const lines: string[] = [
    '引き込まれたのは、',
    'どんな瞬間でしたか。',
  ];

  titleEl.classList.add('mk-typing');
  target.innerHTML = '';

  const cursor = document.createElement('span');
  cursor.className = 'mk-cursor';
  cursor.setAttribute('aria-hidden', 'true');

  let lineIdx = 0;
  let charIdx = 0;
  let currentSpan: HTMLElement | null = null;

  function tick() {
    if (lineIdx >= lines.length) {
      // タイピング完了 — カーソルを短時間だけ残してフェード
      // スニペットのアニメーションは animation-delay で CSS 側制御済み
      setTimeout(() => {
        cursor.style.transition = 'opacity 0.6s';
        cursor.style.opacity = '0';
        setTimeout(() => cursor.remove(), 700);
      }, 900); // 0.9s 点滅後フェード（スニペット開始: 1.8s）
      return;
    }
    const line = lines[lineIdx];
    if (!currentSpan) {
      currentSpan = document.createElement('span');
      currentSpan.style.display = 'block';
      target.appendChild(currentSpan);
      if (lineIdx === 0) target.appendChild(cursor);
    }
    if (charIdx < line.length) {
      currentSpan.textContent += line[charIdx];
      charIdx++;
      setTimeout(tick, 62 + Math.random() * 32);
    } else {
      lineIdx++;
      charIdx = 0;
      currentSpan = null;
      setTimeout(tick, 200);
    }
  }

  setTimeout(tick, 350);
})();
</script>

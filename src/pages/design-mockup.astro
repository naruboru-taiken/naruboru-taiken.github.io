---
// src/pages/design-mockup.astro
// デザインモックアップ v6
// ・noindex設定済み
// ・既存コンポーネント・i18nは一切変更しない
// ・mk-* プレフィックスで既存スタイルと完全分離
---

<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex" />
  <title>デザインモックアップ v6 | ナルボル体験談</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles/global.css" />
</head>
<body>

<!-- ノイズフィルター定義 -->
<svg class="mk-svg-defs" aria-hidden="true" focusable="false">
  <defs>
    <filter id="mk-grain-filter" x="0%" y="0%" width="100%" height="100%" color-interpolation-filters="sRGB">
      <feTurbulence type="fractalNoise" baseFrequency="0.72" numOctaves="4" stitchTiles="stitch" result="noise"/>
      <feColorMatrix type="saturate" values="0" in="noise" result="grayNoise"/>
      <feComposite in="grayNoise" in2="SourceGraphic" operator="in"/>
    </filter>
  </defs>
</svg>

<!-- NOTICE -->
<div class="mk-notice">🎨 デザインモックアップ v6 — 本番未適用・noindex設定済み</div>

<!-- ================================================================
     HEADER
     ================================================================ -->
<header class="mk-header">
  <div class="mk-header-inner">
    <a href="#" class="mk-logo">
      <span class="mk-logo-mark">忍</span>
      <span class="mk-logo-text">ナルボル体験談</span>
    </a>
    <nav class="mk-nav">
      <a href="#" class="mk-nav-link">体験談を読む</a>
      <a href="#" class="mk-nav-link">推しキャラ</a>
      <a href="#" class="mk-btn mk-btn-primary mk-btn-sm">体験談を投稿する</a>
    </nav>
  </div>
</header>

<!-- ================================================================
     HERO — ダーク + チャクラ炎 + コンテンツ予告
     ================================================================ -->
<section class="mk-hero">
  <div class="mk-hero-bg" aria-hidden="true">
    <div class="mk-hero-ambient"></div>
    <div class="mk-hero-chakra"></div>
    <div class="mk-hero-emitter"></div>
    <div class="mk-hero-emitter-core"></div>
    <div class="mk-hero-noise"></div>
    <div class="mk-hero-kanji" aria-hidden="true">忍</div>
  </div>

  <div class="mk-hero-inner">
    <!-- 左: コピー -->
    <div class="mk-hero-copy">
      <p class="mk-eyebrow">NARUTO · BORUTO ファン体験談</p>
      <h1 class="mk-hero-title" aria-label="引き込まれたのは、どんな瞬間でしたか。">
        <span class="mk-typing-target">引き込まれたのは、<br>どんな瞬間でしたか。</span>
      </h1>
      <p class="mk-hero-sub">
        「友達のジャンプが目に入った」「たまたまつけたテレビで流れていた」——<br>
        きっかけは小さくても、あの瞬間がすべてを変えた。
      </p>
      <div class="mk-hero-actions">
        <a href="#" class="mk-btn mk-btn-primary mk-btn-lg">体験談をすべて読む</a>
        <a href="#" class="mk-btn mk-btn-outline-white">あの記憶を投稿する</a>
      </div>
      <!-- グローバル感の強調 -->
      <p class="mk-hero-count">
        日本・ブラジル・韓国など <strong>8ヶ国</strong> から
        <strong>28</strong> の物語が集まっています
      </p>
      <!-- スクロールインジケーター -->
      <div class="mk-scroll-hint" aria-hidden="true">
        <span class="mk-scroll-arrow">↓</span>
      </div>
    </div>

    <!-- 右: 体験談の断片（コンテンツ予告） -->
    <!-- タイピング完了後にフェードイン（animation-delayで制御） -->
    <div class="mk-hero-stories" aria-label="体験談のサンプル" role="complementary">

      <div class="mk-snippet mk-snippet-1">
